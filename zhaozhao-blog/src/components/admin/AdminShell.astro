---
import {
  BookOpenText,
  Boxes,
  FolderKanban,
  Gauge,
  HeartHandshake,
  LayoutTemplate,
  MessageSquareText,
  Music2,
  LogOut,
  Tags,
} from "lucide-astro";

interface Props {
  active: "overview" | "posts" | "projects" | "categories" | "friends" | "messages" | "music" | "content" | "data";
  title: string;
  description: string;
}

const { active, title, description } = Astro.props;
const navigation = [
  { key: "overview", label: "概览", href: "/admin/", icon: Gauge },
  { key: "posts", label: "文章", href: "/admin/posts/", icon: BookOpenText },
  { key: "projects", label: "项目", href: "/admin/projects/", icon: FolderKanban },
  { key: "categories", label: "分类", href: "/admin/categories/", icon: Tags },
  { key: "friends", label: "友链", href: "/admin/friends/", icon: HeartHandshake },
  { key: "messages", label: "留言", href: "/admin/messages/", icon: MessageSquareText },
  { key: "music", label: "音乐", href: "/admin/music/", icon: Music2 },
  { key: "content", label: "页面内容", href: "/admin/content/", icon: LayoutTemplate },
  { key: "data", label: "数据与备份", href: "/admin/data/", icon: Boxes },
] as const;
---

<div class="admin-shell">
  <aside class="admin-sidebar">
    <a class="admin-brand" href="/admin/" aria-label="返回后台概览">
      <span>昭</span>
      <strong>233昭</strong>
      <small>Content desk</small>
    </a>
    <nav aria-label="后台导航">
      {navigation.map(({ key, label, href, icon: Icon }) => (
        <a href={href} aria-current={active === key ? "page" : undefined}>
          <Icon size={18} stroke-width={1.8} aria-hidden="true" />
          <span>{label}</span>
        </a>
      ))}
    </nav>
    <div class="admin-sidebar__footer">
      <a href="/" target="_blank">查看前台 <span aria-hidden="true">↗</span></a>
      <button type="button" data-admin-logout>
        <LogOut size={17} stroke-width={1.8} aria-hidden="true" />
        退出后台
      </button>
    </div>
  </aside>
  <div class="admin-workspace">
    <header class="admin-topbar">
      <div>
        <p>233昭 · 单人工作台</p>
        <h1>{title}</h1>
        <span>{description}</span>
      </div>
      <div class="admin-topbar__actions"><slot name="actions" /></div>
    </header>
    <main id="admin-main" class="admin-main">
      <slot />
    </main>
  </div>
</div>
