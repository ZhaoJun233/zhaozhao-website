---
interface WeatherNotes {
  clear: string;
  cloudy: string;
  rain: string;
  snow: string;
  storm: string;
  fallback: string;
}

interface Props {
  notes: WeatherNotes;
}

const { notes } = Astro.props;
---

<section
  class="now-weather"
  data-home-section="weather"
  data-weather-panel
  aria-label="访客天气"
  aria-live="polite"
  aria-busy="true"
>
  <div class="now-weather__heading">
    <div>
      <p class="now-eyebrow">Weather near you</p>
      <h2 data-weather-area>访客所在区域</h2>
    </div>
    <span class="now-weather__symbol" data-weather-symbol aria-hidden="true">◌</span>
  </div>
  <div class="now-weather__current">
    <strong data-weather-temperature>--°</strong>
    <div>
      <span data-weather-condition>正在望向窗外</span>
      <small data-weather-observed>等待天气回应</small>
    </div>
  </div>
  <dl class="now-weather__details">
    <div><dt>体感</dt><dd data-weather-apparent>--°</dd></div>
    <div><dt>湿度</dt><dd data-weather-humidity>--%</dd></div>
    <div><dt>风</dt><dd data-weather-wind>-- km/h</dd></div>
  </dl>
  <span class="now-weather__status" data-weather-refresh-status aria-live="polite"></span>
  <p class="now-weather__note" data-weather-note>{notes.fallback}</p>
</section>
