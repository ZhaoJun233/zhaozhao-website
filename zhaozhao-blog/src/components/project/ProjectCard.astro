---
import { ExternalLink } from "lucide-astro";
import { siteConfig } from "../../config/site";
import type { RuntimeProject } from "../../lib/runtime-content";

interface Props {
  project: RuntimeProject;
  index: number;
}

const { project, index } = Astro.props;
const projectHref = encodeURI(`/projects/${project.id}/`);
const statusLabels = {
  active: "进行中",
  completed: "已完成",
  archived: "已归档",
} as const;
const dateLabel = new Intl.DateTimeFormat(siteConfig.locale, {
  timeZone: siteConfig.timeZone,
  year: "numeric",
  month: "2-digit",
}).format(project.data.date);
---

<article
  class="project-card surface-card"
  data-project-card
  data-project-status={project.data.status}
  aria-labelledby={`project-title-${index}`}
  data-reveal
>
  <header class="project-card__topline">
    <span class="project-card__number" aria-hidden="true">
      {String(index + 1).padStart(2, "0")}
    </span>
    <span class:list={["project-card__status", `project-card__status--${project.data.status}`]}>
      <i aria-hidden="true"></i>
      {statusLabels[project.data.status]}
    </span>
  </header>

  <div class="project-card__body">
    <p class="project-card__date"><time datetime={project.data.date.toISOString()}>{dateLabel}</time></p>
    <h2 id={`project-title-${index}`}><a href={projectHref}>{project.data.title}</a></h2>
    <p class="project-card__description">{project.data.description}</p>

    <ul class="project-card__tags" aria-label={`${project.data.title} 标签`}>
      {project.data.tags.map((tag) => <li><span aria-hidden="true">#</span>{tag}</li>)}
    </ul>
  </div>

  <footer class="project-card__actions">
    <a class="project-card__detail" href={projectHref} aria-label={`查看项目：${project.data.title}`}>
      阅读项目记录 <span aria-hidden="true">→</span>
    </a>

    {(project.data.repositoryUrl || project.data.demoUrl) && (
      <div class="project-card__external" aria-label="项目外部链接">
        {project.data.repositoryUrl && (
          <a href={project.data.repositoryUrl} target="_blank" rel="noreferrer noopener">
            仓库 <ExternalLink size={13} stroke-width={1.8} aria-hidden="true" />
          </a>
        )}
        {project.data.demoUrl && (
          <a href={project.data.demoUrl} target="_blank" rel="noreferrer noopener">
            演示 <ExternalLink size={13} stroke-width={1.8} aria-hidden="true" />
          </a>
        )}
      </div>
    )}
  </footer>
</article>

<style>
  .project-card {
    position: relative;
    display: flex;
    min-inline-size: 0;
    min-block-size: 25rem;
    flex-direction: column;
    padding: clamp(1.3rem, 3vw, 1.85rem);
    overflow: clip;
    border-radius: var(--radius-card);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .project-card::before {
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: 3px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-pink));
    content: "";
    transform: scaleX(0.2);
    transform-origin: left;
    transition: transform var(--transition-base);
  }

  .project-card:has(h2 a:hover) {
    border-color: color-mix(in srgb, var(--color-accent) 46%, var(--color-border));
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-4px);
  }

  .project-card:has(h2 a:hover)::before {
    transform: scaleX(1);
  }

  .project-card__topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-card__number {
    color: var(--color-text-muted);
    font-family: var(--font-serif);
    font-size: 0.78rem;
    font-style: italic;
  }

  .project-card__status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-text-muted);
    font-size: 0.68rem;
    font-weight: 720;
  }

  .project-card__status i {
    inline-size: 0.45rem;
    block-size: 0.45rem;
    border-radius: 50%;
    background: var(--color-text-muted);
  }

  .project-card__status--active i {
    background: var(--color-success);
    box-shadow: 0 0 0 4px var(--color-success-soft);
  }

  .project-card__status--completed i {
    background: var(--color-accent);
  }

  .project-card__status--archived i {
    background: var(--color-warning);
  }

  .project-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  .project-card__date {
    margin: clamp(2.5rem, 6vw, 4rem) 0 0.45rem;
    color: var(--color-text-muted);
    font-size: 0.66rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
  }

  h2 {
    max-inline-size: 18ch;
    margin: 0;
    font-size: clamp(1.45rem, 3vw, 2rem);
    font-weight: 620;
    letter-spacing: -0.035em;
    line-height: 1.2;
  }

  h2 a {
    text-decoration-color: transparent;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
  }

  h2 a:hover {
    color: var(--color-accent-strong);
    text-decoration-color: var(--color-pink);
  }

  .project-card__description {
    margin: 1rem 0 1.35rem;
    color: var(--color-text-muted);
    font-size: 0.86rem;
    line-height: 1.8;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.75rem;
    margin: auto 0 1.5rem;
    padding: 0;
    color: var(--color-text-muted);
    font-size: 0.68rem;
    list-style: none;
  }

  .project-card__tags span {
    margin-inline-end: 0.2rem;
    color: var(--color-pink);
  }

  .project-card__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    padding-block-start: 1rem;
    border-block-start: 1px solid var(--color-border);
  }

  .project-card__detail {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.73rem;
    font-weight: 740;
    text-decoration: none;
  }

  .project-card__detail:hover {
    color: var(--color-accent-strong);
  }

  .project-card__external {
    display: flex;
    gap: 0.65rem;
  }

  .project-card__external a {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-text-muted);
    font-size: 0.66rem;
    font-weight: 690;
    text-decoration: none;
  }

  .project-card__external a:hover {
    color: var(--color-accent-strong);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-card::before {
      transition: none;
    }

    .project-card:has(h2 a:hover) {
      transform: none;
    }
  }
</style>
