---
import Giscus from "../integrations/Giscus.astro";
import { siteConfig } from "../../config/site";

const { repo, repoId, category, categoryId } = siteConfig.giscus;
const isConfigured = [repo, repoId, category, categoryId].every(
  (value) => typeof value === "string" && value.trim().length > 0,
);
---

{isConfigured && <section class="comments" aria-labelledby="comments-title">
  <header>
    <p class="eyebrow">Conversation · 留言</p>
    <h2 id="comments-title">评论</h2>
    <p>欢迎留下你的想法，也请让讨论保持温柔和具体。</p>
  </header>
  <Giscus />
</section>}

<style>
  .comments {
    margin-block-start: clamp(4rem, 9vw, 7rem);
    padding-block-start: clamp(2rem, 5vw, 3.5rem);
    border-block-start: 1px solid var(--color-border);
  }

  .comments header {
    margin-block-end: 1.5rem;
  }

  .comments h2 {
    margin: 0;
    font-size: clamp(1.55rem, 4vw, 2.3rem);
  }

  .comments header > p:last-child {
    margin: 0.65rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.86rem;
  }
</style>
