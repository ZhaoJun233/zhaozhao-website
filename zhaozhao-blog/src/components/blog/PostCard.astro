---
import type { RuntimePost } from "../../lib/runtime-content";
import PostMeta from "./PostMeta.astro";
import TagList from "./TagList.astro";

export interface Props {
  post: RuntimePost;
  prominence?: "featured" | "standard" | "compact";
  index?: number;
}

const { post, prominence = "standard", index } = Astro.props;
const postHref = encodeURI(`/posts/${post.id}/`);
const hasCover = post.data.coverUrl !== undefined;
---

<article
  class:list={[
    "post-card",
    `post-card--${prominence}`,
    {
      "post-card--without-cover": !hasCover,
      "surface-card": prominence !== "compact",
    },
  ]}
  data-reveal
>
  {hasCover && (
    <div class="post-card__media">
      <img
        src={post.data.coverUrl!}
        alt={post.data.coverAlt!}
        loading={prominence === "featured" ? "eager" : "lazy"}
        decoding="async"
      />
    </div>
  )}
  <div class="post-card__content">
    {prominence === "compact" && typeof index === "number" && (
      <span class="post-card__index" aria-hidden="true">{String(index).padStart(2, "0")}</span>
    )}
    <PostMeta post={post} />
    <h2 class="post-card__title">
      <a href={postHref}>{post.data.title}</a>
    </h2>
    <p class="post-card__description">{post.data.description}</p>
    <TagList tags={post.data.tags} compact={prominence === "compact"} />
  </div>
</article>

<style>
  .post-card {
    position: relative;
    min-width: 0;
  }

  .post-card--featured,
  .post-card--standard {
    display: grid;
    overflow: clip;
    border-radius: var(--radius-card, 8px);
    transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease;
  }

  .post-card--featured {
    grid-template-columns: minmax(0, 1.18fr) minmax(18rem, 0.82fr);
    min-height: clamp(21rem, 36vw, 30rem);
  }

  .post-card--featured.post-card--without-cover {
    grid-template-columns: minmax(0, 1fr);
    min-height: clamp(18rem, 30vw, 24rem);
  }

  .post-card--standard {
    grid-template-columns: minmax(12rem, 0.74fr) minmax(0, 1.26fr);
    min-height: 15rem;
  }

  .post-card--standard.post-card--without-cover {
    grid-template-columns: minmax(0, 1fr);
  }

  .post-card--featured::before,
  .post-card--standard::before {
    position: absolute;
    z-index: 2;
    top: 0;
    left: 1.5rem;
    width: 3rem;
    height: 3px;
    background: linear-gradient(
      90deg,
      var(--color-accent-cyan, #1ca7b5),
      var(--color-accent-pink, #e76f98)
    );
    content: "";
    transition: width 340ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post-card--featured:has(.post-card__title a:hover)::before,
  .post-card--standard:has(.post-card__title a:hover)::before {
    width: calc(100% - 3rem);
  }

  .post-card--featured:has(.post-card__title a:hover),
  .post-card--standard:has(.post-card__title a:hover) {
    border-color: color-mix(
      in srgb,
      var(--color-accent-cyan, #1ca7b5) 48%,
      var(--color-border, transparent)
    );
    box-shadow: var(--shadow-card-hover, 0 16px 42px rgb(10 36 48 / 12%));
    transform: translateY(-3px);
  }

  .post-card__media {
    position: relative;
    display: grid;
    width: 100%;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
    place-items: center;
    background:
      linear-gradient(135deg, rgb(23 165 181 / 16%), rgb(232 111 152 / 12%)),
      var(--color-surface-muted, #eef3f4);
  }

  .post-card__media::after {
    position: absolute;
    z-index: 1;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 42%,
      rgb(255 255 255 / 0.26) 50%,
      transparent 58%
    );
    content: "";
    opacity: 0;
    pointer-events: none;
    transform: translateX(-68%);
    transition:
      opacity 220ms ease,
      transform 920ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post-card:has(.post-card__title a:hover) .post-card__media::after {
    opacity: 1;
    transform: translateX(68%);
  }

  .post-card--featured .post-card__media {
    aspect-ratio: 16 / 9;
  }

  .post-card--standard .post-card__media {
    aspect-ratio: 16 / 9;
  }

  .post-card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition:
      filter 300ms ease,
      transform 620ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post-card:has(.post-card__title a:hover) .post-card__media :global(img) {
    filter: saturate(1.04) brightness(1.02);
    transform: scale(1.045);
  }

  .post-card__content {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(1.35rem, 3vw, 2.6rem);
  }

  .post-card--featured .post-card__content {
    padding-inline: clamp(1.6rem, 4vw, 3.6rem);
  }

  .post-card--featured.post-card--without-cover .post-card__content {
    max-width: 56rem;
    min-height: inherit;
  }

  .post-card__title {
    max-width: 22ch;
    margin: 0.82rem 0 0;
    color: var(--color-text, inherit);
    font-family: var(--font-display, ui-serif, "Noto Serif SC", serif);
    font-size: clamp(1.28rem, 2.3vw, 2rem);
    font-weight: 750;
    line-height: 1.28;
    text-wrap: balance;
  }

  .post-card--featured .post-card__title {
    font-size: clamp(1.7rem, 3.2vw, 2.85rem);
  }

  .post-card__title a {
    color: inherit;
    text-decoration-color: transparent;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    transition: color 180ms ease, text-decoration-color 180ms ease;
  }

  .post-card__title a:hover {
    color: var(--color-accent-cyan-strong, var(--color-accent-cyan, #087f8c));
    text-decoration-color: var(--color-accent-pink, #e76f98);
  }

  .post-card__title a:focus-visible {
    border-radius: 2px;
    outline: var(--focus-ring, 3px solid #00a6b8);
    outline-offset: 5px;
  }

  .post-card__description {
    display: -webkit-box;
    max-width: 54ch;
    margin: 0.8rem 0 1.15rem;
    overflow: hidden;
    color: var(--color-text-muted, color-mix(in srgb, currentColor 70%, transparent));
    font-size: 0.94rem;
    line-height: 1.78;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .post-card--compact {
    display: grid;
    grid-template-columns: minmax(11.5rem, 14.5rem) minmax(0, 1fr);
    gap: clamp(1.1rem, 2.6vw, 2.1rem);
    padding-block: clamp(1.2rem, 2.8vw, 2rem);
    border-bottom: 1px solid var(--color-border, color-mix(in srgb, currentColor 16%, transparent));
    transition: background-color 240ms ease;
  }

  .post-card--compact:has(.post-card__title a:hover) {
    background: color-mix(in srgb, var(--color-accent-soft, #dff5f5) 26%, transparent);
  }

  .post-card--compact:first-child {
    border-top: 1px solid var(--color-border, color-mix(in srgb, currentColor 16%, transparent));
  }

  .post-card--compact .post-card__media {
    aspect-ratio: 16 / 10;
    align-self: start;
    overflow: hidden;
    border-radius: var(--radius-card, 8px);
  }

  .post-card--compact .post-card__media :global(img) {
    object-fit: cover;
  }

  .post-card--compact .post-card__content {
    justify-content: flex-start;
    padding: 0.15rem 0;
    transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post-card--compact:has(.post-card__title a:hover) .post-card__content {
    transform: translateX(0.35rem);
  }

  .post-card__index {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
    color: var(--color-pink-strong, #9f3152);
    font-family: var(--font-display, ui-serif, "Noto Serif SC", serif);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.14em;
  }

  .post-card__index::after {
    width: 1.7rem;
    height: 1px;
    background: currentColor;
    content: "";
    opacity: 0.45;
  }

  .post-card--compact .post-card__title {
    max-width: 30ch;
    margin-top: 0.48rem;
    font-size: clamp(1.08rem, 2vw, 1.42rem);
  }

  .post-card--compact .post-card__title a {
    background-image: linear-gradient(
      var(--color-accent-pink, #e76f98),
      var(--color-accent-pink, #e76f98)
    );
    background-position: 0 97%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    text-decoration: none;
    transition:
      color 180ms ease,
      background-size 360ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post-card--compact .post-card__title a:hover {
    background-size: 100% 1px;
    text-decoration: none;
  }

  .post-card--compact .post-card__description {
    margin: 0.55rem 0 0.75rem;
    font-size: 0.86rem;
    line-height: 1.68;
    -webkit-line-clamp: 2;
  }

  .post-card--compact.post-card--without-cover {
    grid-template-columns: minmax(0, 1fr);
  }

  @media (max-width: 760px) {
    .post-card--featured,
    .post-card--standard,
    .post-card--compact {
      grid-template-columns: minmax(0, 1fr);
    }

    .post-card--featured,
    .post-card--standard {
      min-height: 0;
    }

    .post-card--featured .post-card__media,
    .post-card--standard .post-card__media,
    .post-card--compact .post-card__media {
      aspect-ratio: 16 / 9;
    }

    .post-card--compact .post-card__media {
      width: min(100%, 24rem);
    }

    .post-card__content,
    .post-card--featured .post-card__content {
      padding: 1.35rem;
    }

    .post-card--compact .post-card__content {
      padding: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card,
    .post-card::before,
    .post-card__media::after,
    .post-card__media :global(img),
    .post-card__content,
    .post-card__title a {
      transition: none;
    }

    .post-card--featured:has(.post-card__title a:hover),
    .post-card--standard:has(.post-card__title a:hover),
    .post-card:has(.post-card__title a:hover) .post-card__media :global(img),
    .post-card--compact:has(.post-card__title a:hover) .post-card__content {
      transform: none;
    }

    .post-card:has(.post-card__title a:hover) .post-card__media::after {
      opacity: 0;
    }
  }
</style>
