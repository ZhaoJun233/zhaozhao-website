---
import { siteConfig } from "../../config/site";

interface Props {
  term?: string;
}

const { term } = Astro.props;
const { repo, repoId, category, categoryId } = siteConfig.giscus;
const isConfigured = [repo, repoId, category, categoryId].every(
  (value) => typeof value === "string" && value.trim().length > 0,
);
---

{isConfigured && (
  <div
    class="giscus-placeholder"
    data-giscus-root
    data-repo={repo}
    data-repo-id={repoId}
    data-category={category}
    data-category-id={categoryId}
    data-term={term}
    aria-live="polite"
  >
    <p data-giscus-status>评论将在靠近这里时加载。</p>
  </div>
)}

<script>
  import "../../scripts/comments";
</script>

<style>
  .giscus-placeholder {
    min-block-size: 8rem;
    padding: clamp(1.25rem, 4vw, 2rem);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: var(--color-surface);
  }

  .giscus-placeholder {
    display: grid;
    place-items: center;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    text-align: center;
  }

  .giscus-placeholder > p {
    margin: 0;
  }

  .giscus-placeholder:has(.giscus-frame) {
    display: block;
    padding: 0;
    border: 0;
    background: transparent;
  }

</style>
