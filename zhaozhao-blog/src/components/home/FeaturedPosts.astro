---
import type { HomepageContent } from "../../data/content";
import type { RuntimePost } from "../../lib/runtime-content";
import { resolveHomePostLayout } from "../../lib/home-post-layout";
import PostCard from "../blog/PostCard.astro";

interface Props {
  posts: RuntimePost[];
  copy: HomepageContent["featuredPosts"];
}

const { posts, copy } = Astro.props;
const [leadPost, ...supportingPosts] = posts;
const layout = resolveHomePostLayout(posts.length, leadPost?.data.coverUrl !== undefined);
---

<section
  class="featured-posts section-band"
  id="featured-posts"
  data-testid="featured-posts"
  aria-labelledby="featured-posts-title"
>
  <span class="vertical-accent" aria-hidden="true">綴る</span>
  <div class="section-inner">
    <header class="section-heading" data-reveal>
      <div>
        <p class="section-kicker">{copy.eyebrow} <span>01</span></p>
        <h2 id="featured-posts-title">{copy.title}</h2>
      </div>
      <a class="section-link" href="/posts/">{copy.linkLabel} <span aria-hidden="true">→</span></a>
    </header>

    {leadPost ? (
      <div
        class:list={["posts-layout", `posts-layout--${layout}`]}
        data-layout={layout}
        data-post-count={posts.length}
        data-reveal-stagger="95"
      >
        {layout === "single" ? (
          <div class="lead-post"><PostCard post={leadPost} prominence="featured" /></div>
        ) : layout === "pair" ? (
          posts.map((post) => <PostCard post={post} prominence="standard" />)
        ) : layout === "lead" ? (
          <>
            <div class="lead-post"><PostCard post={leadPost} prominence="featured" /></div>
            {supportingPosts.length > 0 && (
              <div class="supporting-posts">
                {supportingPosts.map((post) => <PostCard post={post} prominence="standard" />)}
              </div>
            )}
          </>
        ) : posts.map((post) => <PostCard post={post} prominence="standard" />)}
      </div>
    ) : (
      <p class="empty-state">{copy.emptyMessage}</p>
    )}
  </div>
</section>

<style>
  .featured-posts {
    position: relative;
    padding: clamp(4.5rem, 8vw, 7.5rem) var(--page-gutter, 1.25rem);
    background:
      radial-gradient(circle at 8% 12%, rgb(87 185 195 / 0.08), transparent 23rem),
      var(--color-bg, #fbfaf7);
    color: var(--color-text, #172b34);
  }

  .vertical-accent {
    position: absolute;
    top: clamp(3.4rem, 7vw, 5.6rem);
    right: max(1.4rem, calc((100vw - var(--content-width, 1180px)) / 2 - 4.2rem));
    color: transparent;
    -webkit-text-stroke: 1px #63949c;
    font-family: var(--font-display, "Iowan Old Style", "Noto Serif SC", serif);
    font-size: clamp(1.6rem, 2.3vw, 2.15rem);
    font-weight: 600;
    letter-spacing: 0.42em;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    writing-mode: vertical-rl;
  }

  @media (max-width: 1279px) {
    .vertical-accent {
      display: none;
    }
  }

  .section-inner {
    width: min(100%, var(--content-width, 1180px));
    margin: 0 auto;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(2rem, 4vw, 3.35rem);
  }

  .section-kicker {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 0.6rem;
    color: var(--color-accent, #087f8c);
    font-size: 0.68rem;
    font-weight: 750;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .section-kicker::before {
    width: 1.9rem;
    height: 1px;
    background: currentColor;
    content: "";
  }

  .section-kicker span {
    color: var(--color-text-muted, #718087);
    font-variant-numeric: tabular-nums;
  }

  h2 {
    max-width: 13ch;
    margin: 0;
    font-family: var(--font-display, "Iowan Old Style", "Noto Serif SC", serif);
    font-size: clamp(2rem, 4.2vw, 3.45rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.14;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-border, #c9d4d7);
    color: var(--color-text, #172b34);
    font-size: 0.78rem;
    font-weight: 680;
    letter-spacing: 0.035em;
    text-decoration: none;
    transition: border-color 180ms ease, color 180ms ease;
  }

  .section-link:hover {
    border-color: var(--color-accent, #087f8c);
    color: var(--color-accent, #087f8c);
  }

  .posts-layout {
    display: grid;
    gap: clamp(1rem, 2.2vw, 1.7rem);
    align-items: stretch;
  }

  .posts-layout--lead {
    grid-template-columns: minmax(0, 1.42fr) minmax(17.5rem, 0.78fr);
  }

  .posts-layout--single {
    grid-template-columns: minmax(0, 1fr);
  }

  .posts-layout--pair {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .lead-post,
  .supporting-posts {
    min-width: 0;
  }

  .lead-post :global(article) {
    height: 100%;
  }

  .posts-layout--pair :global(article),
  .posts-layout--single :global(article) {
    height: 100%;
  }

  .supporting-posts {
    display: grid;
    grid-template-rows: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2.2vw, 1.7rem);
  }

  .supporting-posts :global(article) {
    height: 100%;
  }

  .posts-layout--grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .posts-layout--grid :global(article) {
    height: 100%;
  }

  .empty-state {
    margin: 0;
    padding: 3rem 0;
    border-block: 1px solid var(--color-border, #d5dcde);
    color: var(--color-text-muted, #68777d);
  }

  @media (max-width: 860px) {
    .posts-layout--lead,
    .posts-layout--pair {
      grid-template-columns: 1fr;
    }

    .supporting-posts {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: none;
    }

    .posts-layout--grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .posts-layout--grid :global(article:last-child:nth-child(odd)) {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .featured-posts {
      padding-top: 3.8rem;
      padding-bottom: 4.4rem;
    }

    .section-heading {
      align-items: start;
      margin-bottom: 1.75rem;
    }

    .section-link {
      margin-top: 1.7rem;
      font-size: 0;
    }

    .section-link span {
      font-size: 1rem;
    }

    .supporting-posts {
      grid-template-columns: 1fr;
    }

    .posts-layout--grid {
      grid-template-columns: 1fr;
    }

    .posts-layout--grid :global(article:last-child:nth-child(odd)) {
      grid-column: auto;
    }
  }
</style>
