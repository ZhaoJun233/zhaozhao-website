---
import type { AdminMusicTrack } from "../../lib/database/music-repository";
import MusicPlayer from "../now/MusicPlayer.astro";
import WeatherPanel from "../now/WeatherPanel.astro";

interface Props {
  tracks: AdminMusicTrack[];
  content: {
    hero: {
      eyebrow: string;
      title: string;
      weatherNotes: {
        clear: string;
        cloudy: string;
        rain: string;
        snow: string;
        storm: string;
        fallback: string;
      };
    };
    music: {
      eyebrow: string;
      title: string;
      emptyTitle: string;
      emptyDescription: string;
      openLabel: string;
    };
  };
}

const { tracks, content } = Astro.props;
---

<section
  id="weather-music"
  class="home-weather-music"
  data-home-weather-music
  data-weather-endpoint="/api/weather/"
  aria-label="天气与音乐"
>
  <div class="home-weather-music__glow" aria-hidden="true"></div>
  <div class="home-weather-music__inner">
    <header class="home-weather-music__heading">
      <p>{content.hero.eyebrow}</p>
      <h2>{content.hero.title}</h2>
    </header>
    <div class="home-weather-music__grid">
      <WeatherPanel notes={content.hero.weatherNotes} />
      <MusicPlayer tracks={tracks} content={content.music} />
    </div>
  </div>
  <p class="home-weather-music__privacy">位置仅用于本次天气查询，不会保存。</p>
  <script
    is:inline
    type="application/json"
    data-weather-notes
    set:html={JSON.stringify(content.hero.weatherNotes)}
  ></script>
</section>

<script>
  import "../../scripts/home-weather-music";
</script>

<style>
  .home-weather-music {
    --home-sky: #b8dce5;
    --home-sand: #f2dcc2;
    --home-sea: #4f93a4;
    --home-ink: #183b43;
    position: relative;
    overflow: hidden;
    padding: clamp(3rem, 7vw, 6rem) 0 1rem;
    scroll-margin-top: calc(var(--header-height) + 1rem);
    background:
      radial-gradient(circle at 82% 18%, rgb(255 248 221 / 42%), transparent 26rem),
      linear-gradient(180deg, var(--home-sky) 0%, #d9e8e5 46%, var(--home-sand) 100%);
    color: var(--home-ink);
  }

  .home-weather-music__glow {
    position: absolute;
    inset: 8% 8% auto auto;
    inline-size: min(25vw, 18rem);
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgb(255 244 207 / 58%), rgb(255 226 171 / 16%) 52%, transparent 70%);
    filter: blur(2px);
  }

  .home-weather-music__inner {
    position: relative;
    z-index: 1;
    width: min(calc(100% - 2 * var(--page-gutter)), var(--content-width));
    margin: 0 auto;
  }

  .home-weather-music__heading {
    max-width: 36rem;
    margin-block-end: clamp(1.5rem, 3vw, 2.5rem);
  }

  .home-weather-music__heading p,
  :global(.now-eyebrow) {
    margin: 0 0 .65rem;
    font-size: .64rem;
    font-weight: 800;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  .home-weather-music__heading h2 {
    margin: 0;
    color: currentColor;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 520;
    letter-spacing: -.06em;
    line-height: .95;
  }

  .home-weather-music__grid {
    display: grid;
    grid-template-columns: minmax(18rem, .72fr) minmax(0, 1.28fr);
    align-items: stretch;
    gap: clamp(1rem, 2.5vw, 1.8rem);
  }

  :global(.now-weather) {
    display: flex;
    min-inline-size: 0;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(1.3rem, 3vw, 2rem);
    border: 1px solid rgb(255 255 255 / 18%);
    border-radius: 1.1rem;
    background: rgb(18 52 65 / 83%);
    box-shadow: 0 28px 80px rgb(26 59 69 / 18%);
    color: #f4fbfb;
    backdrop-filter: blur(18px) saturate(1.15);
  }

  :global(.now-weather h2) { margin: 0; color: #fff; font-size: clamp(1.25rem, 2.5vw, 1.8rem); }
  :global(.now-weather__heading) { display: flex; align-items: start; justify-content: space-between; gap: 1rem; }
  :global(.now-weather__symbol) { font-family: var(--font-serif); font-size: 3.4rem; line-height: .8; }
  :global(.now-weather__current) { display: flex; align-items: center; gap: 1rem; margin: 2rem 0; }
  :global(.now-weather__current > strong) { font-family: var(--font-serif); font-size: clamp(4rem, 7vw, 6rem); font-weight: 500; letter-spacing: -.08em; line-height: .8; }
  :global(.now-weather__current div) { display: grid; gap: .25rem; }
  :global(.now-weather__current span) { font-weight: 760; }
  :global(.now-weather__current small) { color: rgb(232 247 248 / 72%); font-size: .62rem; }
  :global(.now-weather__details) { display: grid; grid-template-columns: repeat(3, 1fr); gap: .4rem; margin: 0; }
  :global(.now-weather__details div) { padding: .7rem .45rem; border-block: 1px solid rgb(255 255 255 / 15%); }
  :global(.now-weather__details dt) { color: rgb(232 247 248 / 66%); font-size: .58rem; }
  :global(.now-weather__details dd) { margin: .2rem 0 0; font-family: var(--font-mono); font-size: .7rem; font-weight: 760; }
  :global(.now-weather__note) { margin: 1.5rem 0 0; color: rgb(244 251 251 / 86%); font-family: var(--font-serif); font-size: .9rem; line-height: 1.7; }

  :global(.now-music) {
    min-inline-size: 0;
    margin: 0;
    padding: clamp(1.2rem, 3vw, 2rem);
    border: 1px solid rgb(255 255 255 / 44%);
    border-radius: 1.1rem;
    background: rgb(255 251 244 / 80%);
    box-shadow: 0 28px 80px rgb(71 69 63 / 13%);
    color: #21383d;
    backdrop-filter: blur(18px);
  }

  :global(.now-music__heading) { display: flex; align-items: end; justify-content: space-between; gap: 1rem; margin-block-end: 1.2rem; }
  :global(.now-music__heading h2) { margin: 0; color: #21383d; font-size: clamp(1.5rem, 3vw, 2.3rem); }
  :global(.now-music__heading > span) { color: #597077; font-family: var(--font-mono); font-size: .64rem; text-transform: uppercase; }
  :global(.now-music__body) { display: grid; grid-template-columns: minmax(23rem, .9fr) minmax(0, 1.1fr); gap: 1rem; }
  :global(.now-player-card) { display: grid; grid-template-columns: 8.5rem minmax(0, 1fr); gap: 1rem; align-items: center; padding: 1rem; border: 1px solid rgb(32 65 72 / 14%); border-radius: .8rem; background: #f8efe4; }
  :global(.now-vinyl) { position: relative; display: grid; inline-size: 8rem; aspect-ratio: 1; place-items: center; border-radius: 50%; background: repeating-radial-gradient(circle, #17262a 0 5px, #26383c 6px 7px, #17262a 8px 13px); box-shadow: 0 12px 24px rgb(23 38 42 / 22%); }
  :global(.now-vinyl::before) { position: absolute; inline-size: 35%; aspect-ratio: 1; border-radius: 50%; background: #d98686; content: ""; }
  :global(.now-vinyl span) { position: relative; z-index: 1; inline-size: 8%; aspect-ratio: 1; border-radius: 50%; background: #f8efe4; }
  :global(.now-vinyl[data-selected]) { animation: now-spin 8s linear infinite; }
  :global(.now-player-card__meta) { min-inline-size: 0; }
  :global(.now-player-card__meta > p) { margin: 0 0 .35rem; color: #a05262; font-family: var(--font-mono); font-size: .56rem; font-weight: 800; letter-spacing: .12em; }
  :global(.now-player-card__meta h3) { margin: 0; color: #21383d; font-size: 1.15rem; }
  :global(.now-player-card__meta > span) { display: block; margin: .35rem 0 .75rem; overflow: hidden; color: #627277; font-size: .7rem; text-overflow: ellipsis; white-space: nowrap; }
  :global(.now-player-card__meta a) { display: inline-flex; align-items: center; gap: .35rem; color: #315e69; font-size: .68rem; font-weight: 760; }
  :global(.now-player-frame) { grid-column: 1 / -1; min-inline-size: 0; min-block-size: 86px; overflow: hidden; border-radius: .5rem; background: #fff; }
  :global(.now-player-frame p) { display: flex; min-block-size: 86px; align-items: center; justify-content: center; gap: .5rem; margin: 0; color: #718084; font-size: .68rem; }
  :global(.now-player-frame iframe) { display: block; inline-size: 100%; block-size: 86px; border: 0; }
  :global(.now-track-list) { display: grid; align-content: start; gap: .45rem; }
  :global(.now-track-list button) { display: grid; min-block-size: 4.15rem; min-inline-size: 0; grid-template-columns: 2.2rem 2.8rem minmax(0, 1fr) auto; align-items: center; gap: .65rem; padding: .55rem .7rem; border: 1px solid transparent; border-radius: .65rem; background: rgb(255 255 255 / 58%); color: #263c41; text-align: start; cursor: pointer; transition: border-color 180ms ease, background 180ms ease, transform 180ms ease; }
  :global(.now-track-list button:hover) { border-color: rgb(49 94 105 / 26%); background: #fff; transform: translateX(-2px); }
  :global(.now-track-list button[aria-pressed="true"]) { border-color: #4e7d86; background: #e9f2f1; }
  :global(.now-track-list__index) { color: #8a7874; font-family: var(--font-mono); font-size: .6rem; }
  :global(.now-track-list__cover) { display: grid; inline-size: 2.8rem; aspect-ratio: 1; overflow: hidden; place-items: center; border-radius: .45rem; background: #dce9e8; color: #416c74; }
  :global(.now-track-list__cover img) { inline-size: 100%; block-size: 100%; object-fit: cover; }
  :global(.now-track-list__copy) { display: grid; min-inline-size: 0; gap: .15rem; }
  :global(.now-track-list__copy strong), :global(.now-track-list__copy small) { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  :global(.now-track-list__copy strong) { font-size: .76rem; }
  :global(.now-track-list__copy small) { color: #697a7e; font-size: .62rem; }
  :global(.now-track-list__play) { color: #9b5964; font-family: var(--font-mono); font-size: .55rem; font-weight: 800; letter-spacing: .1em; }
  :global(.now-music-empty) { display: flex; align-items: center; justify-content: center; gap: 1.5rem; min-block-size: 15rem; text-align: start; }
  :global(.now-music-empty h3) { margin: 0 0 .35rem; color: #21383d; }
  :global(.now-music-empty p) { margin: 0; color: #65777b; font-size: .74rem; }

  .home-weather-music__privacy {
    position: relative;
    z-index: 1;
    width: min(calc(100% - 2 * var(--page-gutter)), var(--content-width));
    margin: 1rem auto 0;
    color: color-mix(in srgb, var(--home-ink) 72%, transparent);
    font-size: .62rem;
    text-align: center;
  }

  @keyframes now-spin { to { transform: rotate(1turn); } }

  @media (max-width: 900px) {
    :global(.now-music__body) { grid-template-columns: 1fr; }
  }

  @media (max-width: 760px) {
    .home-weather-music { padding-block-start: 2.5rem; }
    .home-weather-music__grid { grid-template-columns: 1fr; }
    :global(.now-weather) { min-block-size: 23rem; }
    :global(.now-music) { padding: 1rem; }
    :global(.now-player-card) { grid-template-columns: 6.5rem minmax(0, 1fr); }
    :global(.now-vinyl) { inline-size: 6.2rem; }
    :global(.now-track-list button) { min-block-size: 4rem; grid-template-columns: 1.8rem 2.65rem minmax(0, 1fr); }
    :global(.now-track-list__play) { display: none; }
  }

  @media (max-width: 390px) {
    :global(.now-weather__details) { gap: .15rem; }
    :global(.now-player-card) { grid-template-columns: 1fr; text-align: center; }
    :global(.now-vinyl) { margin-inline: auto; }
    :global(.now-player-card__meta a) { justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.now-track-list button) { transition: none; }
    :global(.now-vinyl[data-selected]) { animation: none; }
  }
</style>
