---
import type { AdminMusicTrack } from "../../lib/database/music-repository";
import MusicPlayer from "../now/MusicPlayer.astro";
import WeatherPanel from "../now/WeatherPanel.astro";

interface Props {
  tracks: AdminMusicTrack[];
  content: {
    hero: {
      eyebrow: string;
      title: string;
      weatherNotes: {
        clear: string;
        cloudy: string;
        rain: string;
        snow: string;
        storm: string;
        fallback: string;
      };
    };
    music: {
      eyebrow: string;
      title: string;
      emptyTitle: string;
      emptyDescription: string;
      openLabel: string;
    };
  };
}

const { tracks, content } = Astro.props;
---

<section
  id="weather-music"
  class="hero-weather-music"
  data-home-weather-music
  data-weather-endpoint="/api/weather/"
  data-drawer-open="true"
  aria-label="天气与音乐"
>
  <button
    class="hero-weather-music__toggle"
    type="button"
    aria-controls="hero-weather-music-panel"
    aria-expanded="true"
    data-weather-music-toggle
  >隐藏天气音乐</button>
  <div
    id="hero-weather-music-panel"
    class="hero-weather-music__panel"
    data-weather-music-panel
  >
    <WeatherPanel notes={content.hero.weatherNotes} />
    <MusicPlayer tracks={tracks} content={content.music} />
    <p class="hero-weather-music__privacy">位置仅用于天气与地名查询，不会保存。</p>
  </div>
  <script
    is:inline
    type="application/json"
    data-weather-notes
    set:html={JSON.stringify(content.hero.weatherNotes)}
  ></script>
</section>

<script>
  import "../../scripts/home-weather-music";
</script>

<style>
  .hero-weather-music {
    --drawer-ink: #17333b;
    --drawer-muted: #526b72;
    --drawer-line: rgb(32 73 82 / 14%);
    position: absolute;
    z-index: 5;
    right: max(1.5rem, calc((100vw - var(--content-width, 1180px)) / 2));
    bottom: 4.5rem;
    display: flex;
    width: clamp(20rem, 30vw, 27rem);
    flex-direction: column;
    color: var(--drawer-ink);
  }

  .hero-weather-music__toggle {
    display: flex;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    order: 2;
    margin: .55rem 0 0 auto;
    padding: .62rem .9rem;
    border: 1px solid rgb(255 255 255 / 52%);
    border-radius: 999px;
    background: rgb(248 248 244 / 72%);
    box-shadow: 0 12px 30px rgb(24 50 58 / 14%);
    color: #24444c;
    font: 720 .68rem/1 var(--font-sans);
    letter-spacing: .06em;
    backdrop-filter: blur(16px) saturate(1.08);
    cursor: pointer;
    transition: transform 180ms ease, background-color 180ms ease, box-shadow 180ms ease;
  }

  .hero-weather-music__toggle:hover {
    background: rgb(255 255 252 / 88%);
    box-shadow: 0 15px 34px rgb(24 50 58 / 18%);
    transform: translateY(-1px);
  }

  .hero-weather-music__panel {
    order: 1;
    max-height: 58vh;
    overflow: auto;
    border: 1px solid rgb(255 255 255 / 48%);
    border-radius: 1rem;
    background: rgb(248 248 244 / 62%);
    box-shadow: 0 24px 70px rgb(24 50 58 / 18%);
    backdrop-filter: blur(20px) saturate(1.08);
    scrollbar-width: thin;
    transform-origin: bottom right;
    transition: max-height 220ms ease, opacity 180ms ease, visibility 180ms ease, transform 220ms ease;
  }

  .hero-weather-music[data-drawer-open="false"] .hero-weather-music__panel {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(.65rem) scale(.98);
  }

  :global(.now-eyebrow) {
    margin: 0 0 .3rem;
    color: var(--drawer-muted);
    font-size: .55rem;
    font-weight: 820;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  :global(.now-weather) {
    display: flex;
    min-width: 0;
    flex-direction: column;
    padding: 1rem;
    border-bottom: 1px solid var(--drawer-line);
    background: linear-gradient(135deg, rgb(25 72 82 / 88%), rgb(45 101 109 / 76%));
    color: #f5fbfa;
  }

  :global(.now-weather .now-eyebrow) { color: rgb(236 249 248 / 66%); }
  :global(.now-weather h2) { margin: 0; color: #fff; font-size: 1rem; }
  :global(.now-weather__heading) { display: flex; align-items: start; justify-content: space-between; gap: .75rem; }
  :global(.now-weather__symbol) { font-family: var(--font-serif); font-size: 2.25rem; line-height: .85; }
  :global(.now-weather__current) { display: flex; align-items: center; gap: .8rem; margin: 1rem 0; }
  :global(.now-weather__current > strong) { font-family: var(--font-serif); font-size: clamp(2.65rem, 5vw, 3.25rem); font-weight: 520; letter-spacing: -.08em; line-height: .8; }
  :global(.now-weather__current div) { display: grid; gap: .15rem; }
  :global(.now-weather__current span) { font-size: .82rem; font-weight: 760; }
  :global(.now-weather__current small) { color: rgb(236 249 248 / 70%); font-size: .55rem; }
  :global(.now-weather__details) { display: grid; grid-template-columns: repeat(3, 1fr); gap: .3rem; margin: 0; }
  :global(.now-weather__details div) { padding: .52rem .4rem; border-block: 1px solid rgb(255 255 255 / 14%); }
  :global(.now-weather__details dt) { color: rgb(236 249 248 / 64%); font-size: .52rem; }
  :global(.now-weather__details dd) { margin: .16rem 0 0; font-family: var(--font-mono); font-size: .62rem; font-weight: 760; }
  :global(.now-weather__status) { display: block; min-height: .9rem; margin-top: .45rem; color: #ffe3a7; font-size: .56rem; line-height: .9rem; }
  :global(.now-weather__note) { margin: .78rem 0 0; color: rgb(245 251 250 / 84%); font-family: var(--font-serif); font-size: .72rem; line-height: 1.55; }

  :global(.now-music) {
    min-width: 0;
    margin: 0;
    padding: 1rem;
    color: var(--drawer-ink);
  }

  :global(.now-music__heading) { display: flex; align-items: end; justify-content: space-between; gap: .75rem; margin-bottom: .8rem; }
  :global(.now-music__heading h2) { margin: 0; color: var(--drawer-ink); font-size: 1.15rem; }
  :global(.now-music__heading > span) { color: var(--drawer-muted); font-family: var(--font-mono); font-size: .54rem; text-transform: uppercase; }
  :global(.now-music__body) { display: grid; gap: .7rem; }
  :global(.now-player-card) { display: grid; min-width: 0; grid-template-columns: 4.8rem minmax(0, 1fr); align-items: center; gap: .75rem; padding: .72rem; border: 1px solid var(--drawer-line); border-radius: .72rem; background: rgb(255 252 246 / 68%); }
  :global(.now-vinyl) { position: relative; display: grid; width: 4.5rem; aspect-ratio: 1; place-items: center; border-radius: 50%; background: repeating-radial-gradient(circle, #17262a 0 4px, #26383c 5px 6px, #17262a 7px 11px); box-shadow: 0 9px 19px rgb(23 38 42 / 18%); }
  :global(.now-vinyl::before) { position: absolute; width: 35%; aspect-ratio: 1; border-radius: 50%; background: #d98686; content: ""; }
  :global(.now-vinyl span) { position: relative; z-index: 1; width: 8%; aspect-ratio: 1; border-radius: 50%; background: #f8efe4; }
  :global(.now-vinyl[data-selected]) { animation: now-spin 8s linear infinite; }
  :global(.now-player-card__meta) { min-width: 0; }
  :global(.now-player-card__meta > p) { margin: 0 0 .25rem; color: #a05262; font-family: var(--font-mono); font-size: .5rem; font-weight: 800; letter-spacing: .1em; }
  :global(.now-player-card__meta h3) { margin: 0; overflow: hidden; color: var(--drawer-ink); font-size: .82rem; text-overflow: ellipsis; white-space: nowrap; }
  :global(.now-player-card__meta > span) { display: block; margin: .25rem 0 .42rem; overflow: hidden; color: var(--drawer-muted); font-size: .6rem; text-overflow: ellipsis; white-space: nowrap; }
  :global(.now-player-card__meta a) { display: inline-flex; min-height: 32px; align-items: center; gap: .3rem; color: #315e69; font-size: .6rem; font-weight: 760; }
  :global(.now-player-frame) { grid-column: 1 / -1; min-width: 0; min-height: 86px; overflow: hidden; border-radius: .5rem; background: rgb(255 255 255 / 82%); }
  :global(.now-player-frame p) { display: flex; min-height: 86px; align-items: center; justify-content: center; gap: .45rem; margin: 0; color: #718084; font-size: .6rem; }
  :global(.now-player-frame iframe) { display: block; width: 100%; height: 86px; border: 0; }
  :global(.now-track-list) { display: grid; max-height: 12rem; align-content: start; gap: .35rem; overflow: auto; padding-right: .15rem; }
  :global(.now-track-list button) { display: grid; min-height: 3.45rem; min-width: 0; grid-template-columns: 1.7rem 2.35rem minmax(0, 1fr) auto; align-items: center; gap: .5rem; padding: .42rem .52rem; border: 1px solid transparent; border-radius: .58rem; background: rgb(255 255 255 / 45%); color: var(--drawer-ink); text-align: start; cursor: pointer; transition: border-color 180ms ease, background-color 180ms ease, transform 180ms ease; }
  :global(.now-track-list button:hover) { border-color: rgb(49 94 105 / 26%); background: rgb(255 255 255 / 82%); transform: translateX(-2px); }
  :global(.now-track-list button[aria-pressed="true"]) { border-color: #4e7d86; background: #e9f2f1; }
  :global(.now-track-list__index) { color: #8a7874; font-family: var(--font-mono); font-size: .52rem; }
  :global(.now-track-list__cover) { display: grid; width: 2.35rem; aspect-ratio: 1; overflow: hidden; place-items: center; border-radius: .4rem; background: #dce9e8; color: #416c74; }
  :global(.now-track-list__cover img) { width: 100%; height: 100%; object-fit: cover; }
  :global(.now-track-list__copy) { display: grid; min-width: 0; gap: .1rem; }
  :global(.now-track-list__copy strong),
  :global(.now-track-list__copy small) { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  :global(.now-track-list__copy strong) { font-size: .68rem; }
  :global(.now-track-list__copy small) { color: var(--drawer-muted); font-size: .56rem; }
  :global(.now-track-list__play) { color: #9b5964; font-family: var(--font-mono); font-size: .48rem; font-weight: 800; letter-spacing: .08em; }
  :global(.now-music-empty) { display: flex; align-items: center; justify-content: center; gap: 1rem; min-height: 8rem; text-align: start; }
  :global(.now-music-empty h3) { margin: 0 0 .3rem; color: var(--drawer-ink); font-size: .9rem; }
  :global(.now-music-empty p) { margin: 0; color: var(--drawer-muted); font-size: .64rem; }

  .hero-weather-music__privacy {
    margin: 0;
    padding: 0 1rem .85rem;
    color: var(--drawer-muted);
    font-size: .54rem;
    line-height: 1.45;
    text-align: center;
  }

  :global(html[data-theme="dark"]) .hero-weather-music {
    --drawer-ink: #e8f1ef;
    --drawer-muted: #a7b8b7;
    --drawer-line: rgb(255 255 255 / 12%);
  }

  :global(html[data-theme="dark"]) .hero-weather-music__toggle,
  :global(html[data-theme="dark"]) .hero-weather-music__panel {
    border-color: rgb(255 255 255 / 13%);
    background: rgb(20 31 34 / 72%);
    color: var(--drawer-ink);
  }

  :global(html[data-theme="dark"]) .now-player-card,
  :global(html[data-theme="dark"]) .now-track-list button {
    background: rgb(24 38 41 / 72%);
  }

  @keyframes now-spin { to { transform: rotate(1turn); } }

  @media (max-width: 899px) {
    .hero-weather-music {
      right: 1rem;
      bottom: 1rem;
      left: 1rem;
      width: auto;
    }

    .hero-weather-music__panel { max-height: 70svh; }
    .hero-weather-music__toggle { min-width: 44px; min-height: 44px; }
    :global(.now-player-card__meta a) { min-width: 44px; min-height: 44px; justify-content: center; }
    :global(.now-track-list button) { min-height: 44px; }
  }

  @media (max-width: 390px) {
    :global(.now-track-list button) { grid-template-columns: 1.5rem 2.2rem minmax(0, 1fr); }
    :global(.now-track-list__play) { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-weather-music__toggle,
    .hero-weather-music__panel,
    :global(.now-track-list button) { transition: none; }
    :global(.now-vinyl[data-selected]) { animation: none; }
  }
</style>
