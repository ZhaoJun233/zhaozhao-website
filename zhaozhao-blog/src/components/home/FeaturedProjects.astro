---
import type { HomepageContent } from "../../data/content";
import type { RuntimeProject } from "../../lib/runtime-content";

interface Props {
  projects: RuntimeProject[];
  copy: HomepageContent["featuredProjects"];
}

const { projects, copy } = Astro.props;
const statusLabels = copy.statusLabels;
---

<section class="featured-projects" aria-labelledby="featured-projects-title">
  <div class="projects-inner">
    <header class="projects-heading">
      <div>
        <p>{copy.eyebrow} <span>02</span></p>
        <h2 id="featured-projects-title">{copy.title}</h2>
      </div>
      <p class="projects-intro">{copy.description}</p>
    </header>

    <div class="projects-grid">
      {projects.map((project, index) => (
        <article class="project-card">
          <div class="project-card-topline">
            <span class="project-number">{String(index + 1).padStart(2, "0")}</span>
            <span class:list={["project-status", `project-status-${project.data.status}`]}>
              <i aria-hidden="true"></i>{statusLabels[project.data.status]}
            </span>
          </div>
          <h3><a href={`/projects/${project.id}/`}>{project.data.title}</a></h3>
          <p class="project-description">{project.data.description}</p>
          <ul class="project-tags" aria-label={`${project.data.title} 标签`}>
            {project.data.tags.slice(0, 4).map((tag) => <li>{tag}</li>)}
          </ul>
          <a class="project-link" href={`/projects/${project.id}/`} aria-label={`查看项目：${project.data.title}`}>
            {copy.detailLabel} <span aria-hidden="true">↗</span>
          </a>
        </article>
      ))}
    </div>

    <a class="all-projects-link" href="/projects/">{copy.allLabel} <span aria-hidden="true">→</span></a>
  </div>
</section>

<style>
  .featured-projects {
    padding: clamp(4.7rem, 9vw, 8rem) var(--page-gutter, 1.25rem);
    background:
      radial-gradient(circle at 92% 18%, rgb(234 135 166 / 0.1), transparent 24rem),
      var(--color-bg-soft, #f3f6f4);
    color: var(--color-text, #172b34);
  }

  .projects-inner {
    width: min(100%, var(--content-width, 1180px));
    margin: 0 auto;
  }

  .projects-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(16rem, 27rem);
    align-items: end;
    gap: 3rem;
    margin-bottom: clamp(2.25rem, 4vw, 3.5rem);
  }

  .projects-heading > div > p {
    display: flex;
    align-items: center;
    gap: 0.72rem;
    margin: 0 0 0.65rem;
    color: var(--color-accent, #087f8c);
    font-size: 0.68rem;
    font-weight: 760;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .projects-heading > div > p::before {
    width: 1.9rem;
    height: 1px;
    background: currentColor;
    content: "";
  }

  .projects-heading > div > p span {
    color: var(--color-text-muted, #718087);
  }

  h2 {
    max-width: 13ch;
    margin: 0;
    font-family: var(--font-display, "Iowan Old Style", "Noto Serif SC", serif);
    font-size: clamp(2rem, 4.1vw, 3.35rem);
    font-weight: 590;
    letter-spacing: -0.045em;
    line-height: 1.16;
  }

  .projects-intro {
    margin: 0 0 0.3rem;
    color: var(--color-text-muted, #66777d);
    font-size: 0.93rem;
    line-height: 1.85;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.85rem, 2vw, 1.35rem);
  }

  .project-card {
    position: relative;
    display: flex;
    min-width: 0;
    min-height: 22rem;
    flex-direction: column;
    padding: clamp(1.35rem, 2.4vw, 1.85rem);
    overflow: hidden;
    border: 1px solid var(--color-border, #d3ddde);
    border-radius: var(--radius-card, 8px);
    background: var(--color-surface, #fff);
    box-shadow: 0 12px 36px rgb(22 64 72 / 0.045);
    transition: border-color 200ms ease, box-shadow 200ms ease, transform 200ms ease;
  }

  .project-card::before {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    height: 3px;
    background: linear-gradient(90deg, #15909c, #e88aa7);
    transform: scaleX(0.25);
    transform-origin: left;
    transition: transform 240ms ease;
    content: "";
  }

  .project-card:hover {
    border-color: rgb(14 130 143 / 0.38);
    box-shadow: 0 18px 42px rgb(22 64 72 / 0.1);
    transform: translateY(-4px);
  }

  .project-card:hover::before {
    transform: scaleX(1);
  }

  .project-card-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-number {
    color: var(--color-text-muted, #8a969b);
    font-family: var(--font-display, "Iowan Old Style", serif);
    font-size: 0.78rem;
    font-style: italic;
  }

  .project-status {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    color: var(--color-text-muted, #65767c);
    font-size: 0.68rem;
    font-weight: 680;
  }

  .project-status i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: #829197;
  }

  .project-status-active i {
    background: #1c9b84;
    box-shadow: 0 0 0 4px rgb(28 155 132 / 0.1);
  }

  .project-status-completed i {
    background: #188a9a;
  }

  .project-card h3 {
    margin: 2.25rem 0 0;
    font-family: var(--font-display, "Iowan Old Style", "Noto Serif SC", serif);
    font-size: clamp(1.35rem, 2.2vw, 1.75rem);
    font-weight: 620;
    letter-spacing: -0.025em;
    line-height: 1.25;
  }

  .project-card h3 a {
    color: inherit;
    text-decoration: none;
  }

  .project-card h3 a::after {
    position: absolute;
    inset: 0;
    content: "";
  }

  .project-description {
    margin: 0.9rem 0 1.35rem;
    color: var(--color-text-muted, #66777d);
    font-size: 0.86rem;
    line-height: 1.78;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.7rem;
    margin: auto 0 1.35rem;
    padding: 0;
    list-style: none;
  }

  .project-tags li {
    color: var(--color-text-muted, #66777d);
    font-size: 0.66rem;
  }

  .project-tags li::before {
    margin-right: 0.2rem;
    color: #db7697;
    content: "#";
  }

  .project-link {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border, #dce3e4);
    color: var(--color-text, #172b34);
    font-size: 0.72rem;
    font-weight: 720;
    letter-spacing: 0.045em;
    text-decoration: none;
  }

  .all-projects-link {
    display: flex;
    width: max-content;
    align-items: center;
    gap: 0.7rem;
    margin: 2rem 0 0 auto;
    color: var(--color-text, #172b34);
    font-size: 0.76rem;
    font-weight: 700;
    text-decoration: none;
  }

  .all-projects-link:hover {
    color: var(--color-accent, #087f8c);
  }

  :global(html[data-theme="dark"]) .featured-projects {
    background:
      radial-gradient(circle at 92% 18%, rgb(211 95 133 / 0.09), transparent 24rem),
      var(--color-bg-soft, #152126);
  }

  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .project-card:last-child:nth-child(odd) {
      grid-column: 1 / -1;
      min-height: 18rem;
    }
  }

  @media (max-width: 680px) {
    .projects-heading {
      grid-template-columns: 1fr;
      gap: 1.15rem;
    }

    .projects-intro {
      max-width: 32rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }

    .project-card,
    .project-card:last-child:nth-child(odd) {
      grid-column: auto;
      min-height: 19rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-card::before {
      transition: none;
    }

    .project-card:hover,
    .project-card:hover::before {
      transform: none;
    }
  }
</style>
