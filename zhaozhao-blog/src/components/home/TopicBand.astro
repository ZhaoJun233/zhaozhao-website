---
import type { HomepageContent } from "../../data/content";

export type HomeTopic = {
  label: string;
  href: string;
  count: number;
};

interface Props {
  topics: HomeTopic[];
  copy: HomepageContent["topics"];
}

const { topics, copy } = Astro.props;
---

<section class="topic-band" aria-labelledby="topic-band-title">
  <span class="vertical-accent" aria-hidden="true">感じる</span>
  <div class="topic-inner">
    <header class="topic-heading" data-reveal>
      <p>{copy.eyebrow}</p>
      <h2 id="topic-band-title">{copy.title}</h2>
    </header>
    <nav class="topic-list" aria-label={copy.navigationLabel} data-reveal-stagger="110">
      {topics.map((topic, index) => (
        <a href={topic.href} class="topic-link" data-reveal>
          <span class="topic-index">{String(index + 1).padStart(2, "0")}</span>
          <strong>{topic.label}</strong>
          <span class="topic-count">{topic.count} 篇</span>
          <span class="topic-arrow" aria-hidden="true">↗</span>
        </a>
      ))}
    </nav>
  </div>
</section>

<style>
  .topic-band {
    position: relative;
    padding: clamp(3rem, 6vw, 5rem) var(--page-gutter, 1.25rem);
    overflow: hidden;
    background:
      radial-gradient(circle at 88% -10%, rgb(245 166 189 / 0.14), transparent 22rem),
      radial-gradient(circle at 6% 118%, rgb(126 209 213 / 0.16), transparent 24rem),
      linear-gradient(115deg, rgb(11 125 139 / 0.96), rgb(36 83 93 / 0.98)),
      #1e5963;
    color: #f7fbfa;
  }

  .vertical-accent {
    position: absolute;
    top: clamp(2.4rem, 5vw, 3.6rem);
    right: max(1.4rem, calc((100vw - var(--content-width, 1180px)) / 2 - 4.2rem));
    color: transparent;
    -webkit-text-stroke: 1px rgb(255 255 255 / 0.42);
    font-family: var(--font-display, "Iowan Old Style", "Noto Serif SC", serif);
    font-size: clamp(1.5rem, 2.1vw, 2rem);
    font-weight: 600;
    letter-spacing: 0.4em;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    writing-mode: vertical-rl;
  }

  @media (max-width: 1279px) {
    .vertical-accent {
      display: none;
    }
  }

  .topic-inner {
    width: min(100%, var(--content-width, 1180px));
    margin: 0 auto;
  }

  .topic-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .topic-heading p {
    margin: 0;
    color: rgb(255 255 255 / 0.66);
    font-size: 0.66rem;
    font-weight: 720;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  .topic-heading h2 {
    margin: 0;
    color: #f7fbfa;
    font-family: var(--font-display, "Iowan Old Style", "Noto Serif SC", serif);
    font-size: clamp(1.65rem, 3vw, 2.55rem);
    font-weight: 580;
    letter-spacing: -0.035em;
  }

  .topic-list {
    display: flex;
    flex-wrap: wrap;
    border-top: 1px solid rgb(255 255 255 / 0.24);
    border-left: 1px solid rgb(255 255 255 / 0.2);
  }

  .topic-link {
    position: relative;
    display: grid;
    min-width: 0;
    min-height: 8.6rem;
    flex: 1 1 max(12rem, 25%);
    align-content: center;
    padding: 1.4rem clamp(1rem, 2.1vw, 1.8rem);
    border-right: 1px solid rgb(255 255 255 / 0.2);
    border-bottom: 1px solid rgb(255 255 255 / 0.24);
    color: inherit;
    text-decoration: none;
    transition: background-color 180ms ease;
  }

  .topic-link:hover {
    background: rgb(255 255 255 / 0.09);
  }

  .topic-index {
    margin-bottom: 0.55rem;
    color: #f5a6bd;
    font-size: 0.64rem;
    font-weight: 750;
    letter-spacing: 0.12em;
  }

  .topic-link strong {
    display: inline-block;
    font-family: var(--font-display, "Iowan Old Style", "Noto Serif SC", serif);
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    font-weight: 580;
    transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .topic-link:hover strong {
    transform: translateX(0.32rem);
  }

  .topic-count {
    margin-top: 0.35rem;
    color: rgb(255 255 255 / 0.58);
    font-size: 0.72rem;
  }

  .topic-arrow {
    position: absolute;
    top: 1.2rem;
    right: 1.25rem;
    color: rgb(255 255 255 / 0.58);
    transition: color 180ms ease, transform 180ms ease;
  }

  .topic-link:hover .topic-arrow {
    color: #fff;
    transform: translate(2px, -2px);
  }

  @media (max-width: 600px) {
    .topic-heading {
      display: block;
    }

    .topic-heading p {
      margin-bottom: 0.55rem;
    }

  }

  @media (max-width: 360px) {
    .topic-link {
      flex-basis: 100%;
      min-height: 7.4rem;
      padding-inline: 0.9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .topic-link,
    .topic-arrow,
    .topic-link strong {
      transition: none;
    }

    .topic-link:hover .topic-arrow,
    .topic-link:hover strong {
      transform: none;
    }
  }
</style>
