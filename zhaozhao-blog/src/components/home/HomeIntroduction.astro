---
import type { HomepageContent } from "../../data/content";
import type { RuntimeProfile } from "../../lib/runtime-content";

interface Props {
  profile: RuntimeProfile;
  copy: HomepageContent["introduction"];
  artwork: {
    imageUrl: string;
    alt: string;
    sourceUrl: string;
    uploader: string;
  };
}
const { profile, copy, artwork } = Astro.props;
---

<section
  class="home-introduction"
  data-testid="home-introduction"
  aria-labelledby="home-introduction-title"
>
  <span class="vertical-accent" aria-hidden="true">暮らす</span>
  <div class="introduction-inner">
    <figure class="introduction-artwork" data-reveal="scale">
      <img
        src={artwork.imageUrl}
        alt={artwork.alt}
        loading="lazy"
        decoding="async"
      />
      <div class="artwork-overlay" aria-hidden="true"></div>
      <figcaption>
        <span>{copy.artworkCaption}</span>
        <a href={artwork.sourceUrl} target="_blank" rel="noreferrer">
          画面：{artwork.uploader} <i aria-hidden="true">↗</i>
        </a>
      </figcaption>
    </figure>

    <div class="introduction-copy" data-reveal>
      <p class="introduction-kicker">{copy.eyebrow} <span>03</span></p>
      <h2 id="home-introduction-title">{copy.title}</h2>
      <p class="introduction-lead">{profile.bio}</p>
      <p>
        {copy.body}
      </p>
      <div class="introduction-actions">
        <a class="introduction-primary" href="/about/">{copy.primaryActionLabel} <span aria-hidden="true">→</span></a>
        <a href="/guestbook/">{copy.secondaryActionLabel}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .home-introduction {
    position: relative;
    padding: clamp(5rem, 10vw, 9rem) var(--page-gutter, 1.25rem);
    overflow: hidden;
    background: var(--color-bg, #fbfaf7);
    color: var(--color-text, #172b34);
  }

  .vertical-accent {
    position: absolute;
    top: clamp(3.6rem, 8vw, 6.2rem);
    right: max(1.4rem, calc((100vw - var(--content-width, 1180px)) / 2 - 4.2rem));
    color: transparent;
    -webkit-text-stroke: 1px #63949c;
    font-family: var(--font-display, "Iowan Old Style", "Noto Serif SC", serif);
    font-size: clamp(1.6rem, 2.3vw, 2.15rem);
    font-weight: 600;
    letter-spacing: 0.42em;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    writing-mode: vertical-rl;
  }

  @media (max-width: 1279px) {
    .vertical-accent {
      display: none;
    }
  }

  .introduction-inner {
    display: grid;
    width: min(100%, var(--content-width, 1180px));
    margin: 0 auto;
    grid-template-columns: minmax(0, 1.25fr) minmax(19rem, 0.75fr);
    align-items: center;
    gap: clamp(2.4rem, 6vw, 6.3rem);
  }

  .introduction-artwork {
    position: relative;
    min-width: 0;
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-card, 8px);
    box-shadow: 0 22px 58px rgb(27 56 74 / 0.15);
  }

  .introduction-artwork::before {
    position: absolute;
    z-index: 2;
    inset: 0.7rem;
    border: 1px solid rgb(255 255 255 / 0.34);
    border-radius: 4px;
    content: "";
    pointer-events: none;
  }

  .introduction-artwork :global(img) {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: 43% center;
    transition: transform 900ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .introduction-artwork:hover :global(img) {
    transform: scale(1.035);
  }

  .artwork-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 58%, rgb(23 29 51 / 0.58)),
      linear-gradient(90deg, rgb(20 82 99 / 0.08), rgb(210 99 145 / 0.07));
    pointer-events: none;
  }

  figcaption {
    position: absolute;
    z-index: 3;
    right: 1.6rem;
    bottom: 1.35rem;
    left: 1.6rem;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    color: #fff;
  }

  figcaption > span {
    font-family: var(--font-display, "Iowan Old Style", serif);
    font-size: 1.05rem;
    font-style: italic;
    letter-spacing: 0.04em;
  }

  figcaption a {
    color: rgb(255 255 255 / 0.84);
    font-size: 0.65rem;
    text-decoration: none;
  }

  figcaption a:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  figcaption i {
    font-style: normal;
  }

  .introduction-copy {
    position: relative;
  }

  .introduction-copy::before {
    position: absolute;
    z-index: -1;
    top: -3rem;
    right: -5rem;
    width: 10rem;
    height: 10rem;
    border: 1px solid rgb(13 132 145 / 0.12);
    border-radius: 50%;
    content: "";
  }

  .introduction-kicker {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0 0 0.8rem;
    color: var(--color-accent, #087f8c);
    font-size: 0.67rem;
    font-weight: 760;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .introduction-kicker::before {
    width: 1.8rem;
    height: 1px;
    background: currentColor;
    content: "";
  }

  .introduction-kicker span {
    color: var(--color-text-muted, #718087);
  }

  h2 {
    margin: 0;
    font-family: var(--font-display, "Iowan Old Style", "Noto Serif SC", serif);
    font-size: clamp(2rem, 3.8vw, 3.25rem);
    font-weight: 590;
    letter-spacing: -0.045em;
    line-height: 1.22;
  }

  .introduction-lead {
    margin-top: 1.6rem !important;
    color: var(--color-text, #172b34) !important;
    font-size: 1rem !important;
    font-weight: 650;
  }

  .introduction-copy > p:not(.introduction-kicker) {
    margin: 0.85rem 0 0;
    color: var(--color-text-muted, #65767c);
    font-size: 0.9rem;
    line-height: 1.9;
  }

  .introduction-actions {
    display: flex;
    align-items: center;
    gap: 1.3rem;
    margin-top: 1.8rem;
  }

  .introduction-actions a {
    color: var(--color-text, #172b34);
    font-size: 0.75rem;
    font-weight: 720;
    text-decoration: none;
  }

  .introduction-actions a:hover {
    color: var(--color-accent, #087f8c);
  }

  .introduction-primary {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 0.78rem 1rem;
    border: 1px solid var(--color-border, #ccd7d9);
    border-radius: 4px;
  }

  :global(html[data-theme="dark"]) .introduction-artwork {
    box-shadow: 0 22px 58px rgb(0 0 0 / 0.34);
  }

  @media (max-width: 820px) {
    .introduction-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .introduction-artwork :global(img) {
      aspect-ratio: 16 / 9;
      object-fit: contain;
      background: #26284c;
    }

    .introduction-copy {
      max-width: 38rem;
    }
  }

  @media (max-width: 460px) {
    figcaption {
      right: 1.1rem;
      bottom: 0.9rem;
      left: 1.1rem;
    }

    figcaption > span {
      display: none;
    }

    figcaption a {
      margin-left: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .introduction-artwork :global(img) {
      transition: none;
    }

    .introduction-artwork:hover :global(img) {
      transform: none;
    }
  }
</style>
