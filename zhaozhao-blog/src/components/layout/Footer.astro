---
import { ExternalLink, Github, Rss } from "lucide-astro";
import type { RuntimeNavigation, RuntimeProfile } from "../../lib/runtime-content";

const year = new Date().getFullYear();
interface Props {
  profile: RuntimeProfile;
  navigation: RuntimeNavigation;
}
const { profile, navigation } = Astro.props;
const { footer, items } = navigation;
---

<footer class="site-footer">
  <div class="site-footer__inner site-container" data-reveal="fade">
    <div class="site-footer__identity">
      <a class="site-footer__brand" href="/">{profile.name}</a>
      <p>{profile.bio}</p>
    </div>

    <nav aria-label="页脚导航">
      <span>{footer.navigationLabel}</span>
      <ul>
        {items.slice(1).map((item) => (
          <li><a href={item.href} data-astro-prefetch="viewport">{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-footer__meta">
      <span>{footer.linksLabel}</span>
      <a href="/rss.xml">
        <Rss size={14} stroke-width={1.8} aria-hidden="true" />
        {footer.rssLabel}
      </a>
      <a href="https://github.com/ZhaoJun233" target="_blank" rel="noreferrer noopener">
        <Github size={14} stroke-width={1.8} aria-hidden="true" />
        GitHub
      </a>
      <a href="/credits/">
        <ExternalLink size={14} stroke-width={1.8} aria-hidden="true" />
        {footer.creditsLabel}
      </a>
    </div>
  </div>

  <div class="site-footer__bottom site-container">
    <p>© {year} {profile.name}.</p>
    <p>{footer.note}</p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    padding-block: clamp(3.75rem, 8vw, 6rem) 1.4rem;
    border-block-start: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-soft) 86%, transparent);
    overflow: hidden;
  }

  .site-footer::after {
    position: absolute;
    inset-block-start: -9rem;
    inset-inline-end: -5rem;
    inline-size: 20rem;
    block-size: 20rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 15%, transparent);
    border-radius: 48% 52% 42% 58%;
    content: "";
    pointer-events: none;
    transform: rotate(22deg);
  }

  .site-footer__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(15rem, 1.6fr) minmax(18rem, 1fr) minmax(10rem, 0.65fr);
    gap: clamp(2.5rem, 7vw, 6rem);
  }

  .site-footer__brand {
    display: inline-block;
    margin-block-end: 0.65rem;
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.1rem);
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 1;
    text-decoration: none;
  }

  .site-footer__brand::first-letter {
    color: var(--color-accent-strong);
  }

  .site-footer__identity p {
    max-inline-size: 29ch;
    margin-block-end: 0;
    color: var(--color-text-muted);
    font-family: var(--font-serif);
    font-size: 0.9rem;
    line-height: 1.75;
  }

  .site-footer nav > span,
  .site-footer__meta > span {
    display: block;
    margin-block-end: 0.9rem;
    color: var(--color-text-muted);
    font-size: 0.68rem;
    font-weight: 750;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .site-footer nav ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.6rem 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .site-footer nav a,
  .site-footer__meta a {
    color: var(--color-text-soft);
    font-size: 0.82rem;
    text-decoration: none;
  }

  .site-footer nav a:hover,
  .site-footer__meta a:hover {
    color: var(--color-accent-strong);
  }

  .site-footer__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.7rem;
  }

  .site-footer__meta > span {
    margin-block-end: 0.2rem;
  }

  .site-footer__meta a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .site-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-block-start: clamp(3rem, 7vw, 5rem);
    padding-block-start: 1rem;
    border-block-start: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.7rem;
  }

  .site-footer__bottom p {
    margin: 0;
  }

  @media (max-width: 799px) {
    .site-footer__inner {
      grid-template-columns: 1fr 1fr;
    }

    .site-footer__identity {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 519px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }

    .site-footer__identity {
      grid-column: auto;
    }

    .site-footer__bottom {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
