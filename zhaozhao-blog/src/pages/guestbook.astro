---
import { getDatabase } from "../lib/cloudflare/bindings";
import { listApprovedMessages } from "../lib/database/message-repository";
import { loadRuntimeEditorial, loadRuntimeProfile } from "../lib/runtime-content";
import BaseLayout from "../layouts/BaseLayout.astro";

const [profile, editorial] = await Promise.all([loadRuntimeProfile(), loadRuntimeEditorial()]);
const guestbookContent = editorial.guestbook;
const { hero, guidelines, discussion } = guestbookContent;
const messages = await listApprovedMessages(getDatabase());
---

<BaseLayout
  title="留言簿"
  description={`给 ${profile.name} ${guestbookContent.seoDescription}`}
  page="guestbook"
  class="guestbook-page"
>
  <section class="guestbook-hero" aria-labelledby="guestbook-title">
    <div class="site-container guestbook-hero__inner" data-reveal>
      <div class="guestbook-hero__number" aria-hidden="true">{hero.badge}</div>
      <div>
        <p class="eyebrow">{hero.eyebrow}</p>
        <h1 id="guestbook-title">{hero.title}</h1>
        <p>
          {hero.description}
        </p>
      </div>
    </div>
  </section>

  <section class="guestbook-content" aria-labelledby="guestbook-discussion-title">
    <div class="site-container guestbook-shell">
      <aside class="guestbook-notes" aria-labelledby="guestbook-notes-title" data-reveal="fade">
        <p class="eyebrow">{guidelines.eyebrow}</p>
        <h2 id="guestbook-notes-title">{guidelines.title}</h2>
        <ol>
          {guidelines.items.map((item, index) => (
            <li><span>{String(index + 1).padStart(2, "0")}</span><p>{item}</p></li>
          ))}
        </ol>
        <a href="#guestbook-form">{guidelines.setupLabel} <span aria-hidden="true">→</span></a>
      </aside>

      <div class="guestbook-discussion" data-guestbook-term="guestbook" data-reveal>
        <header>
          <p class="eyebrow">{discussion.eyebrow}</p>
          <h2 id="guestbook-discussion-title">{discussion.title}</h2>
          <p>{discussion.description}</p>
        </header>
        <form id="guestbook-form" class="guestbook-form" data-guestbook-form>
          <div class="guestbook-form__grid">
            <label><span>昵称 *</span><input name="name" maxlength="40" autocomplete="nickname" required /></label>
            <label><span>邮箱</span><input name="email" type="email" autocomplete="email" placeholder="仅博主可见" /></label>
          </div>
          <label><span>个人网站</span><input name="website" type="url" autocomplete="url" placeholder="https://" /></label>
          <label><span>留言 *</span><textarea name="content" minlength="2" maxlength="2000" required></textarea></label>
          <label class="guestbook-honeypot" aria-hidden="true"><span>公司</span><input name="company" tabindex="-1" autocomplete="off" /></label>
          <div class="guestbook-form__footer">
            <p data-guestbook-status aria-live="polite">留言将在审核后公开。</p>
            <button type="submit">提交留言 <span aria-hidden="true">→</span></button>
          </div>
        </form>

        <section class="guestbook-messages" aria-labelledby="guestbook-messages-title">
          <header><p class="eyebrow">Published notes</p><h3 id="guestbook-messages-title">已经留下的回声</h3><span>{messages.length} 条公开留言</span></header>
          {messages.length > 0 ? <ol>
            {messages.map((message, index) => <li>
              <div><span>{String(index + 1).padStart(2, "0")}</span>{message.website ? <a href={message.website} rel="nofollow noreferrer noopener" target="_blank">{message.name}</a> : <strong>{message.name}</strong>}<time datetime={message.createdAt}>{new Date(message.createdAt).toLocaleDateString("zh-CN")}</time></div>
              <p>{message.content}</p>
            </li>)}
          </ol> : <div class="guestbook-empty">第一条公开留言正在等待出现。</div>}
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .guestbook-page {
    overflow: clip;
  }

  .guestbook-hero {
    position: relative;
    padding-block: clamp(4.5rem, 10vw, 8rem) clamp(4rem, 8vw, 6rem);
    border-block-end: 1px solid var(--color-border);
    background:
      radial-gradient(circle at 88% 18%, color-mix(in srgb, var(--color-pink-soft) 76%, transparent), transparent 25rem),
      linear-gradient(120deg, color-mix(in srgb, var(--color-accent-soft) 52%, transparent), transparent 48%);
  }

  .guestbook-hero::after {
    position: absolute;
    inset-inline-end: clamp(1rem, 8vw, 8rem);
    inset-block-end: -2.5rem;
    inline-size: 7rem;
    block-size: 7rem;
    border: 1px solid color-mix(in srgb, var(--color-pink) 28%, transparent);
    border-radius: 50%;
    content: "";
    pointer-events: none;
  }

  .guestbook-hero__inner {
    display: grid;
    grid-template-columns: auto minmax(0, 48rem);
    align-items: center;
    justify-content: start;
    gap: clamp(2rem, 7vw, 6rem);
  }

  .guestbook-hero__number {
    display: grid;
    inline-size: clamp(7rem, 16vw, 12rem);
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--color-accent) 32%, var(--color-border));
    border-radius: 50%;
    color: var(--color-accent-strong);
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    line-height: 1.25;
    text-align: center;
  }

  .guestbook-hero h1 {
    margin: 0;
    font-size: clamp(3.2rem, 9vw, 7rem);
    font-weight: 610;
    letter-spacing: -0.06em;
    line-height: 0.95;
  }

  .guestbook-hero__inner > div:last-child > p:last-child {
    max-inline-size: 43rem;
    margin: 1.25rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.9;
  }

  .guestbook-content {
    padding-block: clamp(4.5rem, 10vw, 8rem);
  }

  .guestbook-shell {
    display: grid;
    grid-template-columns: minmax(15rem, 0.42fr) minmax(0, 1fr);
    align-items: start;
    gap: clamp(2.5rem, 8vw, 7rem);
  }

  .guestbook-notes {
    position: sticky;
    inset-block-start: calc(var(--header-height) + 2rem);
  }

  .guestbook-notes h2,
  .guestbook-discussion h2 {
    margin: 0;
    font-size: clamp(1.55rem, 3vw, 2.2rem);
    letter-spacing: -0.035em;
  }

  .guestbook-notes ol {
    margin: 1.6rem 0 1.5rem;
    padding: 0;
    border-block-start: 1px solid var(--color-border);
    list-style: none;
  }

  .guestbook-notes li {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: 0.75rem;
    padding-block: 0.9rem;
    border-block-end: 1px solid var(--color-border);
  }

  .guestbook-notes li span {
    color: var(--color-pink);
    font-family: var(--font-serif);
    font-size: 0.7rem;
    font-style: italic;
  }

  .guestbook-notes li p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.76rem;
    line-height: 1.75;
  }

  .guestbook-notes > a {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-accent-strong);
    font-size: 0.72rem;
    font-weight: 720;
    text-decoration: none;
  }

  .guestbook-discussion {
    min-inline-size: 0;
  }

  .guestbook-discussion > header {
    margin-block-end: 1.8rem;
    padding-block-end: 1.4rem;
    border-block-end: 1px solid var(--color-border);
  }

  .guestbook-discussion > header > p:last-child {
    max-inline-size: 46rem;
    margin: 0.75rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    line-height: 1.8;
  }

  .guestbook-form {
    display: grid;
    gap: 1rem;
    padding: clamp(1.2rem, 4vw, 2rem);
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface-raised) 92%, transparent);
  }

  .guestbook-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .guestbook-form label:not(.guestbook-honeypot) {
    display: grid;
    gap: 0.4rem;
  }

  .guestbook-form label span {
    color: var(--color-text-soft);
    font-size: 0.7rem;
    font-weight: 720;
  }

  .guestbook-form input,
  .guestbook-form textarea {
    inline-size: 100%;
    padding: 0.75rem 0.8rem;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-control);
    background: var(--color-bg-elevated);
    color: var(--color-text);
    font: inherit;
    font-size: 0.82rem;
  }

  .guestbook-form textarea {
    min-block-size: 9rem;
    resize: vertical;
  }

  .guestbook-honeypot {
    position: absolute;
    inset-inline-start: -10000px;
  }

  .guestbook-form__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .guestbook-form__footer p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.72rem;
  }

  .guestbook-form__footer p[data-error] { color: var(--color-pink-strong); }

  .guestbook-form button {
    display: inline-flex;
    min-block-size: 2.65rem;
    align-items: center;
    gap: 0.7rem;
    padding: 0.65rem 1rem;
    border: 1px solid var(--color-accent-strong);
    border-radius: var(--radius-control);
    background: var(--color-accent-strong);
    color: var(--color-text-inverse);
    font-size: 0.75rem;
    font-weight: 730;
    cursor: pointer;
  }

  .guestbook-messages { margin-block-start: 3rem; }
  .guestbook-messages > header { display: grid; grid-template-columns: 1fr auto; align-items: end; padding-block-end: 1rem; border-block-end: 1px solid var(--color-border); }
  .guestbook-messages > header .eyebrow { grid-column: 1 / -1; }
  .guestbook-messages h3 { margin: 0; font-size: clamp(1.4rem, 3vw, 2rem); }
  .guestbook-messages > header > span { color: var(--color-text-muted); font-size: 0.7rem; }
  .guestbook-messages ol { margin: 0; padding: 0; list-style: none; }
  .guestbook-messages li { padding-block: 1.4rem; border-block-end: 1px solid var(--color-border); }
  .guestbook-messages li > div { display: flex; align-items: baseline; gap: 0.75rem; }
  .guestbook-messages li > div > span { color: var(--color-pink); font-family: var(--font-serif); font-size: 0.65rem; }
  .guestbook-messages li strong, .guestbook-messages li a { font-size: 0.82rem; }
  .guestbook-messages time { margin-inline-start: auto; color: var(--color-text-muted); font-size: 0.65rem; }
  .guestbook-messages li p { margin: 0.75rem 0 0 2rem; color: var(--color-text-soft); font-size: 0.82rem; line-height: 1.8; white-space: pre-wrap; }
  .guestbook-empty { padding: 2rem 0; color: var(--color-text-muted); font-size: 0.78rem; }

  @media (max-width: 760px) {
    .guestbook-hero__inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .guestbook-hero__number {
      inline-size: 6rem;
    }

    .guestbook-shell {
      grid-template-columns: 1fr;
    }

    .guestbook-notes {
      position: static;
    }

    .guestbook-form__grid { grid-template-columns: 1fr; }
    .guestbook-form__footer { align-items: stretch; flex-direction: column; }
  }
</style>
