---
import PostCard from "../../components/blog/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildCategoryIndex, sortPostEntries } from "../../lib/content";
import { loadRuntimeEditorial, loadRuntimePosts } from "../../lib/runtime-content";
import { taxonomySlug } from "../../lib/slug";

const [editorial, allPosts] = await Promise.all([loadRuntimeEditorial(), loadRuntimePosts()]);
const publishedPosts = allPosts.filter(({ data }) => !data.draft);
const categories = buildCategoryIndex(
  editorial.taxonomy.categories,
  publishedPosts.map(({ data }) => data.category),
  { includeUnmanaged: true },
);
const requestedSlug = taxonomySlug(Astro.params.slug ?? "");
const category = categories.find(({ slug }) => slug === requestedSlug);
if (!category) return Astro.redirect("/404/", 302);
const posts = sortPostEntries(
  publishedPosts.filter(
    ({ data }) => taxonomySlug(data.category) === category.slug,
  ),
);
---

<BaseLayout
  title={`分类：${category.label}`}
  description={category.description ?? `浏览 ${posts.length} 篇归入「${category.label}」分类的文章。`}
  class="discovery-page"
>
  <section class="term-page section" aria-labelledby="category-title">
    <div class="site-container term-shell">
      <nav class="breadcrumb" aria-label="面包屑">
        <a href="/categories/">全部分类</a><span aria-hidden="true">/</span><span>{category.label}</span>
      </nav>

      <header class="term-heading" data-reveal>
        <div>
          <p class="eyebrow">Category · 分类</p>
          <h1 id="category-title">{category.label}</h1>
          {category.description && <p class="term-heading__description">{category.description}</p>}
        </div>
        <p class="term-heading__count">
          <strong>{String(posts.length).padStart(2, "0")}</strong>
          <span>篇文章</span>
        </p>
      </header>

      {posts.length > 0 ? (
        <div class="post-list" data-reveal-stagger="90">
          {posts.map((post, itemIndex) => (
            <PostCard post={post} prominence="compact" index={itemIndex + 1} />
          ))}
        </div>
      ) : (
        <section class="empty-state" aria-labelledby="category-empty-title">
          <p aria-hidden="true">○</p>
          <h2 id="category-empty-title">这个分类还没有公开文章</h2>
          <p>内容发布后，这里会自动显示最新条目。</p>
        </section>
      )}

      <a class="back-link" href="/categories/"><span aria-hidden="true">←</span> 返回分类索引</a>
    </div>
  </section>
</BaseLayout>

<style>
  .term-page {
    padding-block: clamp(6.5rem, 12vw, 10rem) clamp(4.5rem, 9vw, 8rem);
  }

  .term-shell {
    max-width: min(62rem, calc(100% - 2rem));
  }

  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    color: var(--color-text-muted, color-mix(in srgb, currentColor 65%, transparent));
    font-size: 0.75rem;
  }

  .breadcrumb a {
    color: inherit;
    text-underline-offset: 0.24em;
  }

  .breadcrumb a:hover {
    color: var(--color-accent-cyan, #087f8c);
  }

  .term-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin: clamp(2.3rem, 6vw, 4.5rem) 0 clamp(2.8rem, 7vw, 5rem);
    padding-bottom: clamp(1.8rem, 4vw, 2.8rem);
    border-bottom: 1px solid var(--color-border, color-mix(in srgb, currentColor 18%, transparent));
  }

  .term-heading h1 {
    max-width: 16ch;
    margin: 0.25rem 0 0;
    font-family: var(--font-display, ui-serif, "Noto Serif SC", serif);
    font-size: clamp(2.7rem, 8vw, 6rem);
    font-weight: 620;
    letter-spacing: -0.04em;
    line-height: 1;
    overflow-wrap: anywhere;
  }

  .term-heading__count {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    margin: 0 0 0.3rem;
    white-space: nowrap;
  }

  .term-heading__description {
    max-width: 36rem;
    margin: 1rem 0 0;
    color: var(--color-text-muted, color-mix(in srgb, currentColor 65%, transparent));
    line-height: 1.8;
  }

  .term-heading__count strong {
    color: var(--color-accent-pink, #d65782);
    font-family: var(--font-display, ui-serif, serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-variant-numeric: tabular-nums;
    font-weight: 560;
    line-height: 1;
  }

  .term-heading__count span {
    color: var(--color-text-muted, color-mix(in srgb, currentColor 62%, transparent));
    font-size: 0.75rem;
  }

  .post-list {
    max-width: 58rem;
    margin-inline: auto;
  }

  .back-link {
    display: inline-flex;
    gap: 0.55rem;
    margin-top: clamp(2.5rem, 6vw, 4.5rem);
    color: var(--color-accent-cyan-strong, var(--color-accent-cyan, #087f8c));
    font-size: 0.8rem;
    font-weight: 720;
    text-underline-offset: 0.25em;
  }

  .empty-state {
    padding: clamp(2.5rem, 8vw, 5rem);
    border-block: 1px solid var(--color-border, color-mix(in srgb, currentColor 18%, transparent));
    text-align: center;
  }

  .empty-state h2 {
    font-family: var(--font-display, ui-serif, serif);
  }

  @media (max-width: 580px) {
    .term-heading {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
