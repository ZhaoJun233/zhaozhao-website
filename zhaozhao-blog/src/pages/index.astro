---
import FeaturedPosts from "../components/home/FeaturedPosts.astro";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomeIntroduction from "../components/home/HomeIntroduction.astro";
import HomeWeatherMusic from "../components/home/HomeWeatherMusic.astro";
import TopicBand, { type HomeTopic } from "../components/home/TopicBand.astro";
import { siteConfig } from "../config/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDatabase } from "../lib/cloudflare/bindings";
import { buildCategoryIndex, sortPostEntries } from "../lib/content";
import { listEnabledMusicTracks } from "../lib/database/music-repository";
import {
  loadRuntimeEditorial,
  loadRuntimePosts,
  loadRuntimeProfile,
  loadRuntimeProjects,
  type RuntimePost,
} from "../lib/runtime-content";

const publishedPosts = sortPostEntries(
  (await loadRuntimePosts()).filter(({ data }) => !data.draft),
);
const featuredPosts = publishedPosts.filter(({ data }) => data.featured);
const selectedPostIds = new Set(featuredPosts.slice(0, 3).map(({ id }) => id));
const homePosts = [
  ...featuredPosts.slice(0, 3),
  ...publishedPosts.filter(({ id }) => !selectedPostIds.has(id)),
].slice(0, 3);

const projects = await loadRuntimeProjects();
const homeProjects = [...projects]
  .sort(
    (left, right) =>
      Number(right.data.featured) - Number(left.data.featured) ||
      right.data.date.getTime() - left.data.date.getTime() ||
      left.id.localeCompare(right.id),
  )
  .slice(0, 3);

const [profile, editorial, tracks] = await Promise.all([
  loadRuntimeProfile(),
  loadRuntimeEditorial(),
  listEnabledMusicTracks(getDatabase()),
]);
const topics: HomeTopic[] = buildCategoryIndex(
  editorial.taxonomy.categories,
  publishedPosts.map(({ data }) => data.category),
).map(({ label, slug, count }) => ({
  label,
  count,
  href: encodeURI(`/categories/${slug}/`),
}));

const latestPost: RuntimePost | undefined = publishedPosts[0];
const latestDate = latestPost?.data.publishedAt;
const latestDateLabel = latestDate
  ? new Intl.DateTimeFormat(siteConfig.locale, {
      timeZone: siteConfig.timeZone,
      month: "2-digit",
      day: "2-digit",
    }).format(latestDate)
  : "—";
const status = editorial.homepage.status;
---

<BaseLayout
  title={`${profile.name} - ${profile.siteTitle}`}
  description={profile.description}
  image={editorial.artwork.homeHero.imageUrl}
  page="home"
  headerOverlay={true}
  runtimeProfile={profile}
  runtimeNavigation={editorial.navigation}
  musicTracks={tracks}
>
  <HomeHero profile={profile} hero={editorial.homepage.hero} heroArtwork={editorial.artwork.homeHero}>
    <HomeWeatherMusic
      slot="weather-music"
      tracks={tracks}
      content={editorial.nowPage}
    />
  </HomeHero>

  <aside class="site-status" aria-label="站点近况">
    <div class="status-inner">
      <p class="status-live"><i aria-hidden="true"></i><span>{status.label}</span><strong>{status.message}</strong></p>
      <dl>
        <div><dt>{status.postsLabel}</dt><dd>{publishedPosts.length}</dd></div>
        <div><dt>{status.topicsLabel}</dt><dd>{topics.length}</dd></div>
        <div><dt>{status.latestLabel}</dt><dd>{latestDateLabel}</dd></div>
      </dl>
      <p class="status-note">{topics.map(({ label }) => label).join(" · ")}</p>
    </div>
  </aside>

  <FeaturedPosts posts={homePosts} copy={editorial.homepage.featuredPosts} />
  <TopicBand topics={topics} copy={editorial.homepage.topics} />
  <FeaturedProjects projects={homeProjects} copy={editorial.homepage.featuredProjects} />
  <HomeIntroduction
    profile={profile}
    copy={editorial.homepage.introduction}
    artwork={editorial.artwork.aboutSummerDream}
  />
</BaseLayout>

<style>
  .site-status {
    position: relative;
    z-index: 5;
    padding: 0 var(--page-gutter);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .status-inner {
    display: grid;
    width: min(100%, var(--content-width));
    min-height: 4.7rem;
    align-items: center;
    margin: 0 auto;
    grid-template-columns: minmax(11rem, 1fr) auto minmax(9rem, 1fr);
    gap: clamp(1.25rem, 4vw, 3rem);
  }

  .status-live {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
    font-size: 0.7rem;
  }

  .status-live i {
    width: 0.44rem;
    height: 0.44rem;
    border-radius: 50%;
    background: var(--color-success, #2f8660);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-success, #2f8660) 12%, transparent);
  }

  .status-live span {
    color: var(--color-text-muted);
    letter-spacing: 0.06em;
  }

  .status-live strong {
    font-weight: 720;
  }

  dl {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.3rem);
    margin: 0;
  }

  dl div {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
  }

  dt {
    color: var(--color-text-muted);
    font-size: 0.66rem;
  }

  dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 650;
    font-variant-numeric: tabular-nums;
  }

  .status-note {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-align: right;
    text-transform: uppercase;
  }

  @media (max-width: 700px) {
    .status-inner {
      min-height: 4.15rem;
      grid-template-columns: 1fr auto;
      gap: 1rem;
    }

    .status-live span,
    .status-note {
      display: none;
    }

    dl {
      gap: 0.8rem;
    }

    dl div:not(:last-child) {
      display: none;
    }
  }
</style>
