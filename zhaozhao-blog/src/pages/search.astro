---
import { Search } from "lucide-astro";
import PostCard from "../components/blog/PostCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortPostEntries } from "../lib/content";
import { loadRuntimeEditorial, loadRuntimePosts, loadRuntimeProfile } from "../lib/runtime-content";

const [profile, editorial] = await Promise.all([loadRuntimeProfile(), loadRuntimeEditorial()]);
const copy = editorial.pageCopy.search;
const query = Astro.url.searchParams.get("q")?.normalize("NFKC").trim() ?? "";
const normalizedQuery = query.toLocaleLowerCase("zh-CN");
const posts = sortPostEntries((await loadRuntimePosts()).filter(({ data }) => !data.draft));
const results = query
  ? posts.filter((post) => [
      post.data.title,
      post.data.description,
      post.data.category,
      ...post.data.tags,
      post.body,
    ].join("\n").normalize("NFKC").toLocaleLowerCase("zh-CN").includes(normalizedQuery))
  : [];
---

<BaseLayout
  title={copy.title}
  description={`${profile.name}：${copy.description}`}
  page="search"
  class="search-page"
>
  <section class="search-section" aria-labelledby="search-page-title">
    <div class="site-container search-shell">
      <header class="search-heading">
        <div>
          <p class="eyebrow">{copy.eyebrow}</p>
          <h1 id="search-page-title">{copy.heading}</h1>
        </div>
        <p>
          {copy.introduction}
        </p>
      </header>

      <div class="search-surface surface-card">
        <form class="runtime-search" action="/search/" method="get" role="search">
          <label for="runtime-search-input">搜索文章</label>
          <div>
            <Search size={18} stroke-width={1.8} aria-hidden="true" />
            <input id="runtime-search-input" name="q" type="search" value={query} placeholder="输入标题、正文、分类或标签" />
            <button type="submit">搜索</button>
          </div>
        </form>

        {query && (
          <section class="runtime-results" aria-live="polite" aria-labelledby="runtime-results-title">
            <h2 id="runtime-results-title">“{query}”找到 {results.length} 篇文章</h2>
            {results.length > 0 ? (
              <div>{results.map((post) => <PostCard post={post} prominence="compact" />)}</div>
            ) : <p>换一个关键词，或从分类和标签入口继续浏览。</p>}
          </section>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .search-section {
    position: relative;
    padding-block: clamp(4rem, 9vw, 7rem) clamp(5rem, 11vw, 8.5rem);
    overflow: clip;
  }

  .search-section::before {
    position: absolute;
    z-index: -1;
    inset-block-start: clamp(2rem, 7vw, 6rem);
    inset-inline-end: clamp(-3rem, 2vw, 4rem);
    inline-size: clamp(11rem, 25vw, 22rem);
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 50%;
    box-shadow:
      0 0 0 clamp(1.5rem, 4vw, 3.5rem) color-mix(in srgb, var(--color-pink-soft) 24%, transparent),
      0 0 0 clamp(4rem, 9vw, 7rem) color-mix(in srgb, var(--color-accent-soft) 18%, transparent);
    content: "";
    pointer-events: none;
  }

  .search-shell {
    max-inline-size: 64rem;
  }

  .search-heading {
    display: grid;
    align-items: end;
    grid-template-columns: minmax(0, 1.25fr) minmax(16rem, 0.75fr);
    gap: clamp(1.5rem, 6vw, 5rem);
    margin-block-end: clamp(2.2rem, 6vw, 4.5rem);
  }

  .search-heading h1 {
    max-inline-size: 12ch;
    margin: 0;
    font-size: clamp(2.65rem, 8vw, 6.1rem);
    font-weight: 620;
    letter-spacing: -0.055em;
    line-height: 0.98;
  }

  .search-heading > p {
    max-inline-size: 35rem;
    margin: 0 0 0.35rem;
    color: var(--color-text-soft);
    font-size: 0.88rem;
    line-height: 1.85;
  }

  .search-surface {
    padding: clamp(1rem, 3.5vw, 2rem);
    border-radius: calc(var(--radius-card) + 4px);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-accent-soft) 22%, transparent), transparent 32%),
      var(--color-surface-raised);
  }

  .runtime-search > label {
    display: block;
    margin-bottom: 0.55rem;
    color: var(--color-text-muted);
    font-size: 0.72rem;
    font-weight: 720;
  }

  .runtime-search > div {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.7rem;
    padding: 0.55rem 0.6rem 0.55rem 0.9rem;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-control);
    background: var(--color-bg);
  }

  .runtime-search input {
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--color-text);
    font: inherit;
  }

  .runtime-search button {
    min-height: 2.45rem;
    padding: 0.55rem 0.9rem;
    border: 0;
    border-radius: 4px;
    background: var(--color-text);
    color: var(--color-text-inverse);
    font-weight: 720;
    cursor: pointer;
  }

  .runtime-results {
    margin-top: 2rem;
  }

  .runtime-results > h2 {
    margin: 0 0 1rem;
    font-size: 1rem;
  }

  .runtime-results > p {
    padding: 2rem 0;
    border-block: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  @media (max-width: 760px) {
    .search-heading {
      align-items: start;
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .search-heading h1 {
      max-inline-size: 11ch;
    }

    .search-heading > p {
      max-inline-size: 42rem;
    }
  }

  @media (max-width: 440px) {
    .search-surface {
      padding: 0.85rem;
    }
  }
</style>
