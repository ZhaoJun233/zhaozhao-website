---
import MusicPlayer from "../components/now/MusicPlayer.astro";
import NowClock from "../components/now/NowClock.astro";
import WeatherPanel from "../components/now/WeatherPanel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDatabase } from "../lib/cloudflare/bindings";
import { listEnabledMusicTracks } from "../lib/database/music-repository";
import { loadRuntimeEditorial, loadRuntimeProfile } from "../lib/runtime-content";

const [editorial, profile, tracks] = await Promise.all([
  loadRuntimeEditorial(),
  loadRuntimeProfile(),
  listEnabledMusicTracks(getDatabase()),
]);
const content = editorial.nowPage;
---

<BaseLayout
  title={`${content.hero.title} · ${profile.name}`}
  description={content.seoDescription}
  page="now"
  mainClass="now-page"
>
  <div class="now-scene" data-now-page data-weather-endpoint="/api/weather">
    <div class="now-scene__glow" aria-hidden="true"></div>
    <div class="now-scene__inner">
      <div class="now-hero-grid">
        <NowClock eyebrow={content.hero.eyebrow} title={content.hero.title} />
        <WeatherPanel notes={content.hero.weatherNotes} />
      </div>
      <MusicPlayer tracks={tracks} content={content.music} />
      <p class="now-privacy">时间只在你的浏览器中计算；位置仅用于本次天气查询，不会保存。</p>
    </div>
    <script is:inline type="application/json" data-weather-notes set:html={JSON.stringify(content.hero.weatherNotes)}></script>
  </div>
  <script>
    import "../scripts/now-page";
  </script>
</BaseLayout>

<style>
  :global(html[data-page="now"]) {
    --now-sky-top: #a7d8e7;
    --now-sky-mid: #e7c6bb;
    --now-horizon: #f0d1b2;
    --now-sea: #4d91a5;
    --now-ink: #15333d;
  }

  :global(html[data-page="now"][data-day-part="dawn"]) {
    --now-sky-top: #9fc8d7;
    --now-sky-mid: #e8bac0;
    --now-horizon: #f2d4b4;
    --now-sea: #5d91a0;
  }

  :global(html[data-page="now"][data-day-part="day"]) {
    --now-sky-top: #84c7df;
    --now-sky-mid: #d8edf0;
    --now-horizon: #f4d9b4;
    --now-sea: #3d8da7;
  }

  :global(html[data-page="now"][data-day-part="dusk"]) {
    --now-sky-top: #879cc1;
    --now-sky-mid: #dc9da2;
    --now-horizon: #efbd96;
    --now-sea: #47778e;
  }

  :global(html[data-page="now"][data-day-part="night"]) {
    --now-sky-top: #172c45;
    --now-sky-mid: #3e506c;
    --now-horizon: #a6787f;
    --now-sea: #183d53;
    --now-ink: #eef8f8;
  }

  :global(.now-page) { padding-block-start: var(--header-height); background: var(--now-sky-top); }
  .now-scene { position: relative; min-block-size: calc(100svh - var(--header-height)); overflow: hidden; color: var(--now-ink); background: linear-gradient(180deg, var(--now-sky-top) 0%, var(--now-sky-mid) 43%, var(--now-horizon) 70%, #e8d4bb 100%); transition: background 900ms ease; }
  .now-scene::before { position: absolute; inset: 48% 0 auto; block-size: 25%; background: linear-gradient(180deg, color-mix(in srgb, var(--now-sea) 84%, white), var(--now-sea)); clip-path: polygon(0 10%, 10% 6%, 20% 12%, 32% 4%, 44% 11%, 58% 3%, 72% 9%, 84% 4%, 100% 12%, 100% 100%, 0 100%); content: ""; opacity: .82; }
  .now-scene::after { position: absolute; inset: 51% 0 auto; block-size: 2px; background: rgb(255 255 255 / 48%); box-shadow: 0 1.15rem 0 rgb(255 255 255 / 18%), 0 2.8rem 0 rgb(255 255 255 / 12%); content: ""; }
  .now-scene__glow { position: absolute; inset: 8% 10% auto auto; inline-size: min(28vw, 22rem); aspect-ratio: 1; border-radius: 50%; background: radial-gradient(circle, rgb(255 244 207 / 78%), rgb(255 226 171 / 24%) 52%, transparent 70%); filter: blur(2px); }
  .now-scene__inner { position: relative; z-index: 2; inline-size: min(calc(100% - 2 * var(--page-gutter)), 1180px); margin: 0 auto; padding: clamp(2rem, 5vw, 4.5rem) 0 3rem; }
  .now-hero-grid { display: grid; grid-template-columns: minmax(0, 1.5fr) minmax(18rem, .72fr); align-items: stretch; gap: clamp(1rem, 2.5vw, 1.8rem); }
  :global(.now-eyebrow) { margin: 0 0 .65rem; font-size: .64rem; font-weight: 800; letter-spacing: .18em; text-transform: uppercase; }
  :global(.now-clock) { position: relative; display: grid; min-block-size: 31rem; overflow: hidden; align-content: space-between; padding: clamp(1.5rem, 4vw, 3.2rem); border: 1px solid rgb(255 255 255 / 44%); border-radius: 1.1rem; background: linear-gradient(135deg, rgb(255 255 255 / 50%), rgb(255 255 255 / 16%)); box-shadow: 0 28px 80px rgb(26 59 69 / 16%); backdrop-filter: blur(12px); }
  :global(.now-clock__copy) { position: relative; z-index: 3; }
  :global(.now-clock h1) { margin: 0; color: currentColor; font-size: clamp(3.4rem, 8vw, 7rem); font-weight: 520; letter-spacing: -.08em; line-height: .92; }
  :global(.now-greeting) { max-inline-size: 34rem; margin: 1rem 0 0; font-size: clamp(.84rem, 1.5vw, 1rem); }
  :global(.now-clock__face) { position: relative; z-index: 4; align-self: end; }
  :global(.now-clock__face time) { display: block; font-family: var(--font-serif); font-size: clamp(4rem, 11vw, 8.6rem); font-variant-numeric: tabular-nums; font-weight: 520; letter-spacing: -.09em; line-height: .82; text-shadow: 0 2px 30px rgb(255 255 255 / 30%); }
  :global(.now-clock__face p) { margin: 1rem 0 0 .3rem; font-size: .72rem; font-weight: 700; letter-spacing: .08em; }
  :global(.now-window) { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
  :global(.now-window__sun) { position: absolute; inset: 14% 12% auto auto; inline-size: 5rem; aspect-ratio: 1; border-radius: 50%; background: #fff0bf; box-shadow: 0 0 70px #ffe4a2; opacity: .72; }
  :global(.now-window__sea) { position: absolute; inset: auto 0 0; block-size: 32%; background: linear-gradient(180deg, rgb(255 255 255 / 18%), color-mix(in srgb, var(--now-sea) 72%, transparent)); clip-path: polygon(0 17%, 14% 10%, 27% 18%, 42% 8%, 58% 15%, 74% 7%, 88% 14%, 100% 8%, 100% 100%, 0 100%); }
  :global(.now-window__rail) { position: absolute; inset: 0 8%; border-inline: 1px solid rgb(255 255 255 / 34%); box-shadow: inset 1px 0 rgb(31 73 82 / 12%); }
  :global(.now-window__cloud) { position: absolute; inline-size: 8rem; block-size: 1.4rem; border-radius: 999px; background: rgb(255 255 255 / 28%); filter: blur(1px); }
  :global(.now-window__cloud--one) { inset: 27% auto auto 38%; }
  :global(.now-window__cloud--two) { inset: 37% 8% auto auto; inline-size: 5rem; opacity: .62; }
  :global(.now-weather) { display: flex; min-inline-size: 0; flex-direction: column; justify-content: space-between; padding: clamp(1.3rem, 3vw, 2rem); border: 1px solid rgb(255 255 255 / 18%); border-radius: 1.1rem; background: rgb(18 52 65 / 83%); box-shadow: 0 28px 80px rgb(26 59 69 / 18%); color: #f4fbfb; backdrop-filter: blur(18px) saturate(1.15); }
  :global(.now-weather h2) { margin: 0; color: #fff; font-size: clamp(1.25rem, 2.5vw, 1.8rem); }
  :global(.now-weather__heading) { display: flex; align-items: start; justify-content: space-between; gap: 1rem; }
  :global(.now-weather__symbol) { font-family: var(--font-serif); font-size: 3.4rem; line-height: .8; }
  :global(.now-weather__current) { display: flex; align-items: center; gap: 1rem; margin: 2rem 0; }
  :global(.now-weather__current > strong) { font-family: var(--font-serif); font-size: clamp(4rem, 7vw, 6rem); font-weight: 500; letter-spacing: -.08em; line-height: .8; }
  :global(.now-weather__current div) { display: grid; gap: .25rem; }
  :global(.now-weather__current span) { font-weight: 760; }
  :global(.now-weather__current small) { color: rgb(232 247 248 / 72%); font-size: .62rem; }
  :global(.now-weather__details) { display: grid; grid-template-columns: repeat(3, 1fr); gap: .4rem; margin: 0; }
  :global(.now-weather__details div) { padding: .7rem .45rem; border-block: 1px solid rgb(255 255 255 / 15%); }
  :global(.now-weather__details dt) { color: rgb(232 247 248 / 66%); font-size: .58rem; }
  :global(.now-weather__details dd) { margin: .2rem 0 0; font-family: var(--font-mono); font-size: .7rem; font-weight: 760; }
  :global(.now-weather__note) { margin: 1.5rem 0 0; color: rgb(244 251 251 / 86%); font-family: var(--font-serif); font-size: .9rem; line-height: 1.7; }
  :global(.now-music) { margin-block-start: clamp(1rem, 2.5vw, 1.8rem); padding: clamp(1.2rem, 3vw, 2rem); border: 1px solid rgb(255 255 255 / 44%); border-radius: 1.1rem; background: rgb(255 251 244 / 80%); box-shadow: 0 28px 80px rgb(71 69 63 / 13%); color: #21383d; backdrop-filter: blur(18px); }
  :global(.now-music__heading) { display: flex; align-items: end; justify-content: space-between; gap: 1rem; margin-block-end: 1.2rem; }
  :global(.now-music__heading h2) { margin: 0; color: #21383d; font-size: clamp(1.5rem, 3vw, 2.3rem); }
  :global(.now-music__heading > span) { color: #597077; font-family: var(--font-mono); font-size: .64rem; text-transform: uppercase; }
  :global(.now-music__body) { display: grid; grid-template-columns: minmax(23rem, .9fr) minmax(0, 1.1fr); gap: 1rem; }
  :global(.now-player-card) { display: grid; grid-template-columns: 8.5rem minmax(0, 1fr); gap: 1rem; align-items: center; padding: 1rem; border: 1px solid rgb(32 65 72 / 14%); border-radius: .8rem; background: #f8efe4; }
  :global(.now-vinyl) { position: relative; display: grid; inline-size: 8rem; aspect-ratio: 1; place-items: center; border-radius: 50%; background: repeating-radial-gradient(circle, #17262a 0 5px, #26383c 6px 7px, #17262a 8px 13px); box-shadow: 0 12px 24px rgb(23 38 42 / 22%); }
  :global(.now-vinyl::before) { position: absolute; inline-size: 35%; aspect-ratio: 1; border-radius: 50%; background: #d98686; content: ""; }
  :global(.now-vinyl span) { position: relative; z-index: 1; inline-size: 8%; aspect-ratio: 1; border-radius: 50%; background: #f8efe4; }
  :global(.now-vinyl[data-selected]) { animation: now-spin 8s linear infinite; }
  :global(.now-player-card__meta) { min-inline-size: 0; }
  :global(.now-player-card__meta > p) { margin: 0 0 .35rem; color: #a05262; font-family: var(--font-mono); font-size: .56rem; font-weight: 800; letter-spacing: .12em; }
  :global(.now-player-card__meta h3) { margin: 0; color: #21383d; font-size: 1.15rem; }
  :global(.now-player-card__meta > span) { display: block; margin: .35rem 0 .75rem; overflow: hidden; color: #627277; font-size: .7rem; text-overflow: ellipsis; white-space: nowrap; }
  :global(.now-player-card__meta a) { display: inline-flex; align-items: center; gap: .35rem; color: #315e69; font-size: .68rem; font-weight: 760; }
  :global(.now-player-frame) { grid-column: 1 / -1; min-inline-size: 0; min-block-size: 86px; overflow: hidden; border-radius: .5rem; background: #fff; }
  :global(.now-player-frame p) { display: flex; min-block-size: 86px; align-items: center; justify-content: center; gap: .5rem; margin: 0; color: #718084; font-size: .68rem; }
  :global(.now-player-frame iframe) { display: block; inline-size: 100%; block-size: 86px; border: 0; }
  :global(.now-track-list) { display: grid; align-content: start; gap: .45rem; }
  :global(.now-track-list button) { display: grid; min-block-size: 4.15rem; min-inline-size: 0; grid-template-columns: 2.2rem 2.8rem minmax(0, 1fr) auto; align-items: center; gap: .65rem; padding: .55rem .7rem; border: 1px solid transparent; border-radius: .65rem; background: rgb(255 255 255 / 58%); color: #263c41; text-align: start; cursor: pointer; transition: border-color 180ms ease, background 180ms ease, transform 180ms ease; }
  :global(.now-track-list button:hover) { border-color: rgb(49 94 105 / 26%); background: #fff; transform: translateX(-2px); }
  :global(.now-track-list button[aria-pressed="true"]) { border-color: #4e7d86; background: #e9f2f1; }
  :global(.now-track-list__index) { color: #8a7874; font-family: var(--font-mono); font-size: .6rem; }
  :global(.now-track-list__cover) { display: grid; inline-size: 2.8rem; aspect-ratio: 1; overflow: hidden; place-items: center; border-radius: .45rem; background: #dce9e8; color: #416c74; }
  :global(.now-track-list__cover img) { inline-size: 100%; block-size: 100%; object-fit: cover; }
  :global(.now-track-list__copy) { display: grid; min-inline-size: 0; gap: .15rem; }
  :global(.now-track-list__copy strong), :global(.now-track-list__copy small) { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  :global(.now-track-list__copy strong) { font-size: .76rem; }
  :global(.now-track-list__copy small) { color: #697a7e; font-size: .62rem; }
  :global(.now-track-list__play) { color: #9b5964; font-family: var(--font-mono); font-size: .55rem; font-weight: 800; letter-spacing: .1em; }
  :global(.now-music-empty) { display: flex; align-items: center; justify-content: center; gap: 1.5rem; min-block-size: 15rem; text-align: start; }
  :global(.now-music-empty h3) { margin: 0 0 .35rem; color: #21383d; }
  :global(.now-music-empty p) { margin: 0; color: #65777b; font-size: .74rem; }
  .now-privacy { margin: 1rem 0 0; color: color-mix(in srgb, var(--now-ink) 72%, transparent); font-size: .62rem; text-align: center; }
  @keyframes now-spin { to { transform: rotate(1turn); } }

  @media (max-width: 900px) {
    .now-hero-grid { grid-template-columns: minmax(0, 1.2fr) minmax(17rem, .8fr); }
    :global(.now-music__body) { grid-template-columns: 1fr; }
  }

  @media (max-width: 760px) {
    .now-scene__inner { padding-block-start: 1rem; }
    .now-hero-grid { display: contents; }
    .now-scene__inner { display: flex; flex-direction: column; }
    :global(.now-clock) { order: 1; min-block-size: 29rem; padding: 1.3rem; }
    :global(.now-weather) { order: 2; margin-block-start: .8rem; min-block-size: 23rem; }
    :global(.now-music) { order: 3; margin-block-start: .8rem; padding: 1rem; }
    .now-privacy { order: 4; }
    :global(.now-clock__face time) { font-size: clamp(4.1rem, 22vw, 6.4rem); }
    :global(.now-player-card) { grid-template-columns: 6.5rem minmax(0, 1fr); }
    :global(.now-vinyl) { inline-size: 6.2rem; }
    :global(.now-track-list button) { min-block-size: 4rem; grid-template-columns: 1.8rem 2.65rem minmax(0, 1fr); }
    :global(.now-track-list__play) { display: none; }
  }

  @media (max-width: 390px) {
    :global(.now-weather__details) { gap: .15rem; }
    :global(.now-player-card) { grid-template-columns: 1fr; text-align: center; }
    :global(.now-vinyl) { margin-inline: auto; }
    :global(.now-player-card__meta a) { justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .now-scene, :global(.now-track-list button) { transition: none; }
    :global(.now-vinyl[data-selected]) { animation: none; }
  }
</style>
