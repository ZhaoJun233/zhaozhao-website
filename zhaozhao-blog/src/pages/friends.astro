---
import { ExternalLink } from "lucide-astro";
import { loadRuntimeEditorial } from "../lib/runtime-content";
import BaseLayout from "../layouts/BaseLayout.astro";

const friendsContent = (await loadRuntimeEditorial()).friends;
const { hero, invitation, links: friends } = friendsContent;
---

<BaseLayout
  title="友链"
  description={friendsContent.seoDescription}
  page="friends"
  class="friends-page"
>
  <section class="friends-hero" aria-labelledby="friends-title">
    <div class="site-container friends-hero__inner">
      <div>
        <p class="eyebrow">{hero.eyebrow}</p>
        <h1 id="friends-title">{hero.title}</h1>
      </div>
      <p>
        {hero.description}
      </p>
    </div>
  </section>

  <section class="friends-directory" aria-labelledby="friends-directory-title">
    <div class="site-container">
      <div class="friends-notice" role="note">
        <span aria-hidden="true">i</span>
        <div>
          <h2 id="friends-directory-title">{friendsContent.noticeTitle}</h2>
          <p>{friendsContent.notice}</p>
        </div>
      </div>

      {friends.length > 0 ? (
        <ul class="friends-grid" aria-label="友链列表">
          {friends.map((friend, index) => (
            <li>
              <a
                class="friend-card"
                data-friend-card
                href={friend.url}
                target="_blank"
                rel="noreferrer noopener nofollow"
                aria-label={`访问友链：${friend.name}`}
              >
                <span class="friend-card__number" aria-hidden="true">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <div>
                  <h3>{friend.name}</h3>
                  <p>{friend.description}</p>
                </div>
                <ul aria-label={`${friend.name} 兴趣`}>
                  {friend.interests.map((interest) => <li>{interest}</li>)}
                </ul>
                <span class="friend-card__visit">
                  {friendsContent.visitLabel} <ExternalLink size={15} stroke-width={1.8} aria-hidden="true" />
                </span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="friends-empty" role="status">
          <h2>{friendsContent.emptyTitle}</h2>
          <p>{friendsContent.emptyDescription}</p>
        </div>
      )}

      <aside class="friends-invitation" aria-labelledby="friends-invitation-title">
        <p class="eyebrow">{invitation.eyebrow}</p>
        <h2 id="friends-invitation-title">{invitation.title}</h2>
        <p>
          {invitation.description}
        </p>
        <a href="/guestbook/">{invitation.actionLabel} <span aria-hidden="true">→</span></a>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .friends-page {
    overflow: clip;
  }

  .friends-hero {
    position: relative;
    padding-block: clamp(4.5rem, 10vw, 8rem) clamp(4rem, 8vw, 6rem);
    border-block-end: 1px solid var(--color-border);
    overflow: hidden;
  }

  .friends-hero::after {
    position: absolute;
    inset-block-start: 12%;
    inset-inline-end: -5rem;
    inline-size: 20rem;
    block-size: 20rem;
    border: 1px solid color-mix(in srgb, var(--color-pink) 20%, transparent);
    border-radius: 46% 54% 58% 42%;
    content: "";
    pointer-events: none;
    transform: rotate(20deg);
  }

  .friends-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(17rem, 0.55fr);
    align-items: end;
    gap: clamp(2rem, 8vw, 8rem);
  }

  .friends-hero h1 {
    max-inline-size: 15ch;
    margin: 0;
    font-size: clamp(2.65rem, 7vw, 5.8rem);
    font-weight: 610;
    letter-spacing: -0.05em;
    line-height: 1.05;
  }

  .friends-hero__inner > p {
    margin: 0 0 0.35rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.9;
  }

  .friends-directory {
    padding-block: clamp(3rem, 7vw, 5rem) clamp(5rem, 11vw, 8.5rem);
  }

  .friends-notice {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 1rem;
    max-inline-size: 48rem;
    margin-block-end: clamp(2rem, 5vw, 3.5rem);
    padding: 1rem 1.15rem;
    border-inline-start: 3px solid var(--color-accent);
    background: color-mix(in srgb, var(--color-accent-soft) 58%, transparent);
  }

  .friends-notice > span {
    display: grid;
    inline-size: 2.15rem;
    block-size: 2.15rem;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--color-accent) 28%, transparent);
    border-radius: 50%;
    color: var(--color-accent-strong);
    font-family: var(--font-serif);
    font-size: 0.9rem;
    font-style: italic;
  }

  .friends-notice h2 {
    margin: 0 0 0.15rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
  }

  .friends-notice p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.75rem;
  }

  .friends-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    margin: 0;
    padding: 1px;
    background: var(--color-border);
    list-style: none;
  }

  .friends-grid > li {
    min-inline-size: 0;
    background: var(--color-bg);
  }

  .friend-card {
    position: relative;
    display: grid;
    min-block-size: 21rem;
    grid-template-rows: auto 1fr auto auto;
    gap: 1.35rem;
    padding: clamp(1.4rem, 4vw, 2.25rem);
    overflow: hidden;
    background:
      linear-gradient(145deg, transparent 62%, color-mix(in srgb, var(--color-accent-soft) 46%, transparent)),
      var(--color-bg);
    text-decoration: none;
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .friend-card::after {
    position: absolute;
    inset-inline-end: -2.5rem;
    inset-block-end: -3rem;
    inline-size: 8rem;
    block-size: 8rem;
    border: 1px solid color-mix(in srgb, var(--color-pink) 21%, transparent);
    border-radius: 50%;
    content: "";
    transition: transform var(--transition-base);
  }

  .friend-card:hover {
    color: var(--color-accent-strong);
  }

  .friend-card:hover::after {
    transform: scale(1.13) translate(-0.35rem, -0.35rem);
  }

  .friend-card__number {
    color: var(--color-text-muted);
    font-family: var(--font-serif);
    font-size: 0.72rem;
    font-style: italic;
  }

  .friend-card h3 {
    max-inline-size: 13ch;
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 2.35rem);
    font-weight: 600;
    letter-spacing: -0.04em;
  }

  .friend-card p {
    max-inline-size: 34rem;
    margin: 0.8rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    line-height: 1.85;
  }

  .friend-card ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .friend-card ul li {
    padding: 0.28rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    color: var(--color-text-muted);
    background: var(--color-surface);
    font-size: 0.65rem;
    font-weight: 680;
  }

  .friend-card__visit {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    padding-block-start: 0.9rem;
    border-block-start: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: 0.7rem;
    font-weight: 740;
  }

  .friends-invitation {
    display: grid;
    max-inline-size: 46rem;
    margin: clamp(4rem, 10vw, 7.5rem) auto 0;
    justify-items: center;
    text-align: center;
  }

  .friends-invitation h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
  }

  .friends-invitation > p:not(.eyebrow) {
    margin: 1rem 0 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.86rem;
    line-height: 1.85;
  }

  .friends-invitation a {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding-block-end: 0.3rem;
    border-block-end: 1px solid var(--color-pink);
    font-size: 0.76rem;
    font-weight: 740;
    text-decoration: none;
  }

  .friends-empty {
    padding: 4rem 2rem;
    border-block: 1px solid var(--color-border);
    text-align: center;
  }

  .friends-empty p {
    color: var(--color-text-muted);
  }

  @media (max-width: 760px) {
    .friends-hero__inner {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 1.5rem;
    }

    .friends-hero__inner > p {
      max-inline-size: 34rem;
    }

    .friends-grid {
      grid-template-columns: 1fr;
    }

    .friend-card {
      min-block-size: 19rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .friend-card,
    .friend-card::after {
      transition: none;
    }

    .friend-card:hover::after {
      transform: none;
    }
  }
</style>
