---
import { Download, Upload } from "lucide-astro";
import AdminShell from "../../components/admin/AdminShell.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="数据与备份">
  <AdminShell active="data" title="数据与备份" description="导出或恢复全站数据库内容。">
    <div class="admin-data-actions">
      <section class="admin-data-card"><Download size={24} color="#086d77" /><h2>导出全量备份</h2><p>下载包含文章、项目、分类、友链和所有页面设置的 JSON 文件。</p><a class="admin-button admin-button--primary" href="/api/admin/export/">下载 JSON 备份</a></section>
      <section class="admin-data-card"><Upload size={24} color="#a93658" /><h2>导入备份</h2><p>系统会先完整校验文件，然后在单个事务中替换当前内容。</p><form class="admin-form" data-import-form><div class="admin-field"><label for="backup-file">JSON 备份文件</label><input id="backup-file" name="backup" type="file" accept="application/json,.json" required /></div><p class="admin-status" data-admin-status aria-live="polite"></p><button class="admin-button admin-button--danger" type="submit">校验并导入</button></form></section>
    </div>
  </AdminShell>
</AdminLayout>
