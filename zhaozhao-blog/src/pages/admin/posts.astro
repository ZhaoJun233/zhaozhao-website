---
import { FileUp, Pencil, Plus, Save, Trash2, X } from "lucide-astro";
import AdminShell from "../../components/admin/AdminShell.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { listCategories, listPosts } from "../../lib/database/admin-repository";
import { getContentDatabase } from "../../lib/database/legacy-content-database";

const database = getContentDatabase();
const posts = listPosts(database);
const categories = listCategories(database).filter(({ enabled }) => enabled);
const config = { endpoint: "/api/admin/posts", confirmName: "文章", fields: [
  { name: "slug", type: "text" }, { name: "title", type: "text" },
  { name: "description", type: "textarea" }, { name: "body", type: "textarea" },
  { name: "publishedAt", type: "date" }, { name: "updatedAt", type: "date", optional: true },
  { name: "draft", type: "checkbox" }, { name: "category", type: "text" },
  { name: "tags", type: "tags" }, { name: "cover", type: "text", optional: true },
  { name: "coverAlt", type: "text", optional: true }, { name: "featured", type: "checkbox" },
  { name: "series", type: "text", optional: true }, { name: "canonicalUrl", type: "text", optional: true },
] };
---

<AdminLayout title="文章管理">
  <AdminShell active="posts" title="文章管理" description="正文、草稿、分类与发布信息都保存在数据库。">
    <div slot="actions" class="admin-actions">
      <input type="file" accept=".md,.markdown,text/markdown" data-import-post-file hidden />
      <button class="admin-button" type="button" data-import-post><FileUp size={16} />导入 Markdown</button>
      <button class="admin-button admin-button--primary" type="button" data-create-record><Plus size={16} />新建文章</button>
    </div>
    <div class="admin-split" data-record-page>
      <section class="admin-panel" style="margin:0">
        <div class="admin-panel__header"><div><h2>文章列表</h2><p>{posts.length} 篇文章，其中 {posts.filter(({ draft }) => draft).length} 篇草稿。</p></div></div>
        <div class="admin-table-wrap"><table class="admin-table"><thead><tr><th>文章</th><th>分类</th><th>状态</th><th>日期</th><th></th></tr></thead><tbody>
          {posts.map((post) => <tr data-record-id={post.id}>
            <td><div class="admin-table__title"><strong>{post.title}</strong><span>/{post.slug}/ · {post.description}</span></div></td>
            <td>{post.category}</td>
            <td><span class:list={["admin-badge", { "admin-badge--muted": post.draft }]}>{post.draft ? "草稿" : "已发布"}</span></td>
            <td>{post.publishedAt.slice(0, 10)}</td>
            <td><div class="admin-actions"><button class="admin-button admin-button--small" type="button" data-edit-record={post.id}><Pencil size={14} />编辑</button><button class="admin-button admin-button--small admin-button--danger" type="button" data-delete-record={post.id}><Trash2 size={14} />删除</button></div></td>
          </tr>)}
        </tbody></table></div>
      </section>
      <aside class="admin-editor"><h2 data-editor-title>新增内容</h2><p>Slug 保存后用于文章永久链接。</p>
        <form class="admin-form" data-record-form><input type="hidden" name="id" />
          <div class="admin-field"><label for="post-title">标题</label><input id="post-title" name="title" required /></div>
          <div class="admin-field"><label for="post-slug">Slug</label><input id="post-slug" name="slug" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" required /></div>
          <div class="admin-field"><label for="post-description">摘要</label><textarea id="post-description" name="description" required></textarea></div>
          <div class="admin-field"><label for="post-category">分类</label><select id="post-category" name="category" required><option value="">选择分类</option>{categories.map((category) => <option value={category.name}>{category.name}</option>)}</select></div>
          <div class="admin-field"><label for="post-tags">标签</label><input id="post-tags" name="tags" placeholder="Astro, TypeScript" required /></div>
          <div class="admin-field"><label for="post-published">发布日期</label><input id="post-published" name="publishedAt" type="date" required /></div>
          <div class="admin-field"><label for="post-updated">更新日期</label><input id="post-updated" name="updatedAt" type="date" /></div>
          <div class="admin-field"><label for="post-body">Markdown 正文</label><textarea id="post-body" name="body" data-body required></textarea></div>
          <div class="admin-field"><label for="post-cover">封面路径</label><input id="post-cover" name="cover" /></div>
          <div class="admin-field"><label for="post-cover-alt">封面说明</label><input id="post-cover-alt" name="coverAlt" /></div>
          <div class="admin-field"><label for="post-series">系列</label><input id="post-series" name="series" /></div>
          <div class="admin-field"><label for="post-canonical">规范链接</label><input id="post-canonical" name="canonicalUrl" type="url" /></div>
          <label class="admin-field--check"><input name="draft" type="checkbox" />保存为草稿</label>
          <label class="admin-field--check"><input name="featured" type="checkbox" />首页精选</label>
          <p class="admin-status" data-record-status aria-live="polite"></p>
          <div class="admin-form__actions"><button class="admin-button admin-button--primary" type="submit"><Save size={15} />保存文章</button><button class="admin-button" type="button" data-cancel-edit><X size={15} />清空</button></div>
        </form>
      </aside>
      <script is:inline type="application/json" data-record-config set:html={JSON.stringify(config)}></script>
    </div>
  </AdminShell>
</AdminLayout>
