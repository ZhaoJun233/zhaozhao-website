---
import { ExternalLink } from "lucide-astro";
import type { ArtworkPlacement } from "../data/artwork";
import { loadRuntimeEditorial } from "../lib/runtime-content";
import BaseLayout from "../layouts/BaseLayout.astro";

const editorial = await loadRuntimeEditorial();
const creditsContent = editorial.credits;
const artworkRecords = [
  { ...editorial.artwork.homeHero, placements: ["home-hero"] as const },
  { ...editorial.artwork.aboutSummerDream, placements: ["home-intro", "about-hero"] as const },
];
const placementLabels: Record<ArtworkPlacement, string> = {
  "home-hero": "首页主视觉",
  "home-intro": "首页个人介绍",
  "about-hero": "关于页主视觉",
};
const { hero, artwork: artworkCopy, libraries } = creditsContent;
---

<BaseLayout
  title={creditsContent.title}
  description={creditsContent.description}
  page="credits"
  class="credits-page"
>
  <section class="credits-hero" aria-labelledby="credits-title">
    <div class="site-container credits-hero__inner" data-reveal>
      <div>
        <p class="eyebrow">{hero.eyebrow}</p>
        <h1 id="credits-title">{hero.heading}</h1>
      </div>
      <p>
        {hero.introduction}
      </p>
    </div>
  </section>

  <section class="credits-artwork" aria-labelledby="artwork-title">
    <div class="site-container">
      <header class="credits-heading">
        <p class="eyebrow">{artworkCopy.eyebrow}</p>
        <h2 id="artwork-title">{artworkCopy.heading}</h2>
        <p>{artworkCopy.introduction}</p>
      </header>

      <div class="artwork-list" data-reveal-stagger="110">
        {artworkRecords.map((record, index) => (
          <article class="artwork-record" data-reveal>
            <figure>
              <img
                src={record.imageUrl}
                alt={record.alt}
                loading="lazy"
              />
            </figure>
            <div class="artwork-record__content">
              <span class="artwork-record__number" aria-hidden="true">
                {String(index + 1).padStart(2, "0")}
              </span>
              <h3>{record.title}</h3>
              <dl>
                <div><dt>替代文字</dt><dd>{record.alt}</dd></div>
                <div>
                  <dt>展示位置</dt>
                  <dd>{record.placements.map((placement) => placementLabels[placement]).join("、")}</dd>
                </div>
                {"uploader" in record ? (
                  <div><dt>上传者</dt><dd>{record.uploader}</dd></div>
                ) : (
                  <div><dt>来源</dt><dd>站点作者提供的本地素材</dd></div>
                )}
                {"bvid" in record && <div><dt>BV 号</dt><dd><code>{record.bvid}</code></dd></div>}
              </dl>
              {"sourceUrl" in record && (
                <a href={record.sourceUrl} target="_blank" rel="noreferrer noopener">
                  {artworkCopy.sourceLinkLabel}
                  <ExternalLink size={15} stroke-width={1.8} aria-hidden="true" />
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="credits-libraries" aria-labelledby="libraries-title">
    <div class="site-container credits-libraries__inner">
      <header class="credits-heading">
        <p class="eyebrow">{libraries.eyebrow}</p>
        <h2 id="libraries-title">{libraries.heading}</h2>
      </header>

      <ul class="library-list" data-reveal-stagger="70">
        {libraries.items.map((library) => (
          <li data-reveal>
            <div><strong>{library.name}</strong><span>{library.license}</span></div>
            <p>{library.role}</p>
            <a href={library.url} target="_blank" rel="noreferrer noopener">
              {libraries.linkLabel} <ExternalLink size={14} stroke-width={1.8} aria-hidden="true" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>

<style>
  .credits-page {
    overflow: clip;
  }

  .credits-hero {
    position: relative;
    padding-block: clamp(4.5rem, 10vw, 8rem) clamp(4rem, 8vw, 6rem);
    border-block-end: 1px solid var(--color-border);
    background:
      radial-gradient(circle at 88% 22%, color-mix(in srgb, var(--color-pink-soft) 72%, transparent), transparent 24rem),
      linear-gradient(120deg, color-mix(in srgb, var(--color-accent-soft) 54%, transparent), transparent 48%);
  }

  .credits-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(17rem, 0.48fr);
    align-items: end;
    gap: clamp(2rem, 8vw, 8rem);
  }

  .credits-hero h1 {
    max-inline-size: 14ch;
    margin: 0;
    font-size: clamp(2.65rem, 7vw, 5.8rem);
    font-weight: 610;
    letter-spacing: -0.052em;
    line-height: 1.05;
  }

  .credits-hero__inner > p {
    margin: 0 0 0.3rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.9;
  }

  .credits-artwork,
  .credits-libraries {
    padding-block: clamp(4.5rem, 10vw, 8rem);
  }

  .credits-heading {
    max-inline-size: 48rem;
    margin-block-end: clamp(2.5rem, 6vw, 4rem);
  }

  .credits-heading h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.7rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 1.12;
  }

  .credits-heading > p:last-child {
    max-inline-size: 56ch;
    margin: 0.9rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.84rem;
    line-height: 1.8;
  }

  .artwork-list {
    display: grid;
    gap: clamp(2rem, 6vw, 4.5rem);
  }

  .artwork-record {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(17rem, 0.82fr);
    align-items: center;
    gap: clamp(1.6rem, 6vw, 5rem);
  }

  .artwork-record:nth-child(even) figure {
    grid-column: 2;
    grid-row: 1;
  }

  .artwork-record figure {
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: var(--color-bg-soft);
    box-shadow: var(--shadow-card);
  }

  .artwork-record figure :global(img) {
    inline-size: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .artwork-record:nth-child(2) figure :global(img) {
    object-position: 43% center;
  }

  .artwork-record__number {
    color: var(--color-pink);
    font-family: var(--font-serif);
    font-size: 0.78rem;
    font-style: italic;
  }

  .artwork-record h3 {
    margin: 0.8rem 0 0;
    font-size: clamp(1.45rem, 3vw, 2.2rem);
    letter-spacing: -0.035em;
  }

  .artwork-record dl {
    margin: 1.4rem 0 1.25rem;
    border-block-start: 1px solid var(--color-border);
  }

  .artwork-record dl div {
    display: grid;
    grid-template-columns: 5.5rem minmax(0, 1fr);
    gap: 1rem;
    padding-block: 0.7rem;
    border-block-end: 1px solid var(--color-border);
  }

  .artwork-record dt {
    color: var(--color-text-muted);
    font-size: 0.66rem;
  }

  .artwork-record dd {
    margin: 0;
    color: var(--color-text-soft);
    font-size: 0.75rem;
    line-height: 1.7;
  }

  .artwork-record code {
    font-family: var(--font-mono);
    font-size: 0.82em;
  }

  .artwork-record__content > a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-accent-strong);
    font-size: 0.72rem;
    font-weight: 720;
    text-decoration: none;
  }

  .artwork-record__content > a:hover {
    text-decoration: underline;
  }

  .credits-libraries {
    border-block: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-soft) 80%, transparent);
  }

  .credits-libraries__inner {
    display: grid;
    grid-template-columns: minmax(17rem, 0.55fr) minmax(0, 1fr);
    align-items: start;
    gap: clamp(2rem, 8vw, 8rem);
  }

  .library-list {
    margin: 0;
    padding: 0;
    border-block-start: 1px solid var(--color-border);
    list-style: none;
  }

  .library-list li {
    display: grid;
    grid-template-columns: minmax(8rem, 0.6fr) minmax(12rem, 1fr) auto;
    align-items: center;
    gap: 1rem;
    padding-block: 1rem;
    border-block-end: 1px solid var(--color-border);
  }

  .library-list li > div {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
  }

  .library-list strong {
    font-family: var(--font-serif);
    font-size: 0.92rem;
  }

  .library-list span {
    color: var(--color-pink);
    font-size: 0.58rem;
    font-weight: 760;
  }

  .library-list p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.73rem;
  }

  .library-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-accent-strong);
    font-size: 0.66rem;
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 820px) {
    .credits-hero__inner,
    .credits-libraries__inner {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .credits-hero__inner > p {
      max-inline-size: 36rem;
    }

    .artwork-record,
    .artwork-record:nth-child(even) {
      grid-template-columns: 1fr;
    }

    .artwork-record:nth-child(even) figure {
      grid-column: auto;
      grid-row: auto;
    }

  }

  @media (max-width: 560px) {
    .library-list li {
      grid-template-columns: 1fr auto;
    }

    .library-list p {
      grid-column: 1 / -1;
      grid-row: 2;
    }
  }
</style>
