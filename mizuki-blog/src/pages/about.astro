---
import { ExternalLink, Rss } from "lucide-astro";
import { loadRuntimeEditorial, loadRuntimeProfile } from "../lib/runtime-content";
import BaseLayout from "../layouts/BaseLayout.astro";

const [profile, editorial] = await Promise.all([loadRuntimeProfile(), loadRuntimeEditorial()]);
const aboutContent = editorial.about;
const artwork = editorial.artwork.aboutSummerDream;
const { hero, interests, workbench, timeline } = aboutContent;
---

<BaseLayout
  title={`关于 ${profile.name}`}
  description={`${profile.name}：${aboutContent.seoDescription}`}
  image={artwork.imageUrl}
  type="profile"
  page="about"
  class="about-page"
>
  <section class="about-hero" aria-labelledby="about-title">
    <figure class="about-artwork">
      <img
        src={artwork.imageUrl}
        alt={artwork.alt}
        loading="eager"
        fetchpriority="high"
      />
      <div class="about-artwork__veil" aria-hidden="true"></div>
      <figcaption>
        <span>{artwork.title}</span>
        <a
          href={artwork.sourceUrl}
          target="_blank"
          rel="noreferrer noopener"
          aria-label={`查看《${artwork.title}》来源（Bilibili）`}
        >
          画面：{artwork.uploader}
          <ExternalLink size={14} stroke-width={1.8} aria-hidden="true" />
        </a>
      </figcaption>
    </figure>

    <div class="site-container about-profile">
      <div class="about-profile__avatar">
        <img
          src={profile.avatarUrl}
          alt={`${profile.name} 的头像`}
          width={176}
          height={176}
          loading="eager"
        />
      </div>
      <div class="about-profile__copy">
        <p class="eyebrow">{hero.eyebrow}</p>
        <h1 id="about-title">{profile.name}</h1>
        <p class="about-profile__bio">{profile.bio}</p>
        <p>
          {hero.introduction}
        </p>
      </div>
      <nav class="about-profile__links" aria-label="联系与订阅">
        <a href="/guestbook/">{hero.guestbookLabel} <span aria-hidden="true">→</span></a>
        <a href="/rss.xml">
          <Rss size={15} stroke-width={1.8} aria-hidden="true" /> {hero.rssLabel}
        </a>
      </nav>
    </div>
  </section>

  <section class="about-interests" aria-labelledby="interests-title">
    <div class="site-container">
      <header class="about-section-heading">
        <p class="eyebrow">{interests.eyebrow}</p>
        <h2 id="interests-title">{interests.title}</h2>
        <p>{interests.description}</p>
      </header>

      <ol class="interest-list">
        {interests.items.map((interest, index) => (
          <li>
            <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
            <h3>{interest.title}</h3>
            <p>{interest.description}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="about-workbench" aria-labelledby="tools-title">
    <div class="site-container about-workbench__inner">
      <div>
        <p class="eyebrow">{workbench.eyebrow}</p>
        <h2 id="tools-title">{workbench.title}</h2>
      </div>
      <div class="about-workbench__copy">
        <p>
          {workbench.description}
        </p>
        <ul aria-label="常用工具列表">
          {workbench.tools.map((tool) => <li>{tool}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="about-timeline" aria-labelledby="timeline-title">
    <div class="site-container about-timeline__inner">
      <header class="about-section-heading">
        <p class="eyebrow">{timeline.eyebrow}</p>
        <h2 id="timeline-title">{timeline.title}</h2>
        <p>{timeline.description}</p>
      </header>

      <ol class="timeline-list">
        {timeline.entries.map((entry) => (
          <li>
            <time datetime={`${entry.date}-01`}>{entry.date.replace("-", ".")}</time>
            <div>
              <h3>{entry.title}</h3>
              <p>{entry.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page {
    overflow: clip;
  }

  .about-hero {
    position: relative;
    padding-block-end: clamp(4.5rem, 10vw, 8rem);
  }

  .about-artwork {
    position: relative;
    inline-size: 100%;
    block-size: clamp(23rem, 54vw, 46rem);
    margin: 0;
    overflow: hidden;
    background: #272950;
  }

  .about-artwork :global(img) {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: 43% center;
  }

  .about-artwork__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgb(18 25 45 / 5%) 35%, rgb(16 24 38 / 68%) 100%),
      linear-gradient(90deg, rgb(17 104 123 / 10%), rgb(212 87 133 / 8%));
    pointer-events: none;
  }

  .about-artwork::after {
    position: absolute;
    inset: 1rem;
    border: 1px solid rgb(255 255 255 / 34%);
    content: "";
    pointer-events: none;
  }

  .about-artwork figcaption {
    position: absolute;
    z-index: 2;
    inset-inline: max(var(--page-gutter), calc((100vw - var(--content-width)) / 2));
    inset-block-end: clamp(5rem, 9vw, 7rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: #fff;
  }

  .about-artwork figcaption > span {
    font-family: var(--font-serif);
    font-size: 0.83rem;
    font-style: italic;
    letter-spacing: 0.04em;
  }

  .about-artwork figcaption a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgb(255 255 255 / 84%);
    font-size: 0.68rem;
    font-weight: 680;
    text-decoration: none;
  }

  .about-artwork figcaption a:hover {
    color: #fff;
    text-decoration: underline;
  }

  .about-profile {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: end;
    gap: clamp(1.4rem, 4vw, 3rem);
    margin-block-start: clamp(-5.5rem, -7vw, -3.75rem);
    padding: clamp(1.35rem, 4vw, 2.5rem);
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-elevated) 94%, transparent);
    box-shadow: var(--shadow-float);
    backdrop-filter: blur(18px);
  }

  .about-profile__avatar {
    align-self: start;
    inline-size: max-content;
    justify-self: start;
    padding: 0.35rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-card);
  }

  .about-profile__avatar :global(img) {
    inline-size: clamp(7rem, 13vw, 11rem);
    block-size: clamp(7rem, 13vw, 11rem);
    object-fit: cover;
  }

  .about-profile__copy {
    max-inline-size: 42rem;
  }

  .about-profile__copy .eyebrow {
    margin-block-end: 0.3rem;
  }

  .about-profile h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 610;
    letter-spacing: -0.06em;
    line-height: 0.95;
  }

  .about-profile__bio {
    margin: 1.1rem 0 0 !important;
    color: var(--color-text) !important;
    font-weight: 720;
  }

  .about-profile__copy > p:not(.eyebrow) {
    margin: 0.65rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.86rem;
    line-height: 1.85;
  }

  .about-profile__links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    padding-block-end: 0.2rem;
  }

  .about-profile__links a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.7rem;
    font-weight: 720;
    text-decoration: none;
    white-space: nowrap;
  }

  .about-profile__links a:hover {
    color: var(--color-accent-strong);
  }

  .about-interests {
    padding-block: clamp(4rem, 9vw, 7rem);
    border-block: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-soft) 78%, transparent);
  }

  .about-section-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(15rem, 0.45fr);
    align-items: end;
    gap: 1rem 4rem;
    margin-block-end: clamp(2.5rem, 6vw, 4rem);
  }

  .about-section-heading .eyebrow {
    grid-column: 1 / -1;
    margin: 0;
  }

  .about-section-heading h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.7rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 1.12;
  }

  .about-section-heading > p:last-child {
    margin: 0 0 0.25rem;
    color: var(--color-text-muted);
    font-size: 0.84rem;
    line-height: 1.8;
  }

  .interest-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 0;
    padding: 0;
    border-block-start: 1px solid var(--color-border);
    list-style: none;
  }

  .interest-list li {
    min-inline-size: 0;
    padding: clamp(1.3rem, 3vw, 2rem);
    border-inline-end: 1px solid var(--color-border);
  }

  .interest-list li:first-child {
    border-inline-start: 1px solid var(--color-border);
  }

  .interest-list > li > span {
    color: var(--color-pink);
    font-family: var(--font-serif);
    font-size: 0.72rem;
    font-style: italic;
  }

  .interest-list h3 {
    margin: clamp(2.2rem, 5vw, 4rem) 0 0;
    font-size: 1.15rem;
  }

  .interest-list p {
    margin: 0.65rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.78rem;
    line-height: 1.8;
  }

  .about-workbench {
    padding-block: clamp(5rem, 11vw, 9rem);
  }

  .about-workbench__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(18rem, 0.75fr);
    gap: clamp(2rem, 9vw, 9rem);
  }

  .about-workbench h2 {
    max-inline-size: 16ch;
    margin: 0;
    font-size: clamp(2.15rem, 5vw, 4rem);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 1.1;
  }

  .about-workbench__copy > p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.87rem;
    line-height: 1.9;
  }

  .about-workbench__copy ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1.6rem 0 0;
    padding: 0;
    list-style: none;
  }

  .about-workbench__copy li {
    padding: 0.48rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    color: var(--color-text-soft);
    font-size: 0.7rem;
    font-weight: 680;
  }

  .about-timeline {
    padding-block: clamp(4.5rem, 10vw, 8rem);
    border-block-start: 1px solid var(--color-border);
    background:
      radial-gradient(circle at 92% 18%, color-mix(in srgb, var(--color-pink-soft) 55%, transparent), transparent 24rem),
      color-mix(in srgb, var(--color-bg-soft) 82%, transparent);
  }

  .timeline-list {
    position: relative;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .timeline-list::before {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 6.25rem;
    inline-size: 1px;
    background: var(--color-border-strong);
    content: "";
  }

  .timeline-list li {
    position: relative;
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    padding-block: 1.4rem;
  }

  .timeline-list li::before {
    position: absolute;
    inset-block-start: 2rem;
    inset-inline-start: 5.93rem;
    inline-size: 0.68rem;
    block-size: 0.68rem;
    border: 2px solid var(--color-bg-soft);
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent);
    content: "";
  }

  .timeline-list time {
    padding-block-start: 0.2rem;
    color: var(--color-accent-strong);
    font-family: var(--font-serif);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    text-align: end;
  }

  .timeline-list div {
    max-inline-size: 44rem;
    padding-block-end: 1.25rem;
    border-block-end: 1px solid var(--color-border);
  }

  .timeline-list h3 {
    margin: 0;
    font-size: 1.08rem;
  }

  .timeline-list p {
    margin: 0.5rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    line-height: 1.8;
  }

  @media (max-width: 920px) {
    .about-profile {
      grid-template-columns: auto minmax(0, 1fr);
      align-items: start;
    }

    .about-profile__links {
      grid-column: 2;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .interest-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .interest-list li:nth-child(3) {
      border-inline-start: 1px solid var(--color-border);
    }
  }

  @media (max-width: 680px) {
    .about-artwork {
      block-size: clamp(22rem, 118vw, 31rem);
    }

    .about-artwork :global(img) {
      object-position: 40% center;
    }

    .about-artwork figcaption > span {
      display: none;
    }

    .about-artwork figcaption a {
      margin-inline-start: auto;
    }

    .about-profile {
      grid-template-columns: 1fr;
      align-items: start;
      margin-block-start: -3rem;
    }

    .about-profile__avatar :global(img) {
      inline-size: 7.5rem;
      block-size: 7.5rem;
    }

    .about-profile__links {
      grid-column: auto;
    }

    .about-section-heading,
    .about-workbench__inner {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 1.2rem;
    }

    .interest-list {
      grid-template-columns: 1fr;
    }

    .interest-list li,
    .interest-list li:nth-child(3) {
      border-inline: 1px solid var(--color-border);
      border-block-end: 1px solid var(--color-border);
    }

    .interest-list h3 {
      margin-block-start: 1.5rem;
    }

    .timeline-list::before {
      inset-inline-start: 0.35rem;
    }

    .timeline-list li {
      grid-template-columns: 1fr;
      gap: 0.4rem;
      padding-inline-start: 1.9rem;
    }

    .timeline-list li::before {
      inset-inline-start: 0.02rem;
    }

    .timeline-list time {
      text-align: start;
    }
  }
</style>
