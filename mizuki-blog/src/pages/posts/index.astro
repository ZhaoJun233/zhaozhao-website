---
import { getCollection } from "astro:content";
import PostCard from "../../components/blog/PostCard.astro";
import Pagination from "../../components/blog/Pagination.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../config/site";
import { paginate, sortPostEntries } from "../../lib/content";

const posts = sortPostEntries(await getCollection("posts", ({ data }) => !data.draft));
const page = paginate(posts, 1, siteConfig.pageSize);
---

<BaseLayout
  title="文章"
  description={`浏览 ${siteConfig.name} 关于动画、开发、阅读与日常的全部文章。`}
  class="discovery-page"
>
  <section class="posts-page section" aria-labelledby="posts-title">
    <div class="site-container">
      <header class="page-heading">
        <div>
          <p class="eyebrow">Writing index · 文章索引</p>
          <h1 id="posts-title">所有文章</h1>
          <p class="page-heading__intro">
            把动画片段、开发笔记与生活里的微光，按时间轻轻收在这里。
          </p>
        </div>
        <div class="page-heading__aside" aria-label="文章索引概览">
          <p><strong>{page.total}</strong><span>篇已发布</span></p>
          <nav aria-label="浏览方式">
            <a href="/categories/">按分类</a>
            <a href="/tags/">按标签</a>
            <a href="/archive/">时间归档</a>
          </nav>
        </div>
      </header>

      {page.items.length > 0 ? (
        <div class="post-list">
          {page.items.map((post) => <PostCard post={post} prominence="compact" />)}
        </div>
      ) : (
        <section class="empty-state" aria-labelledby="posts-empty-title">
          <p aria-hidden="true">✦</p>
          <h2 id="posts-empty-title">新的文字正在路上</h2>
          <p>这里暂时还没有公开文章，过一会儿再来看看吧。</p>
        </section>
      )}

      <Pagination currentPage={page.page} pageCount={page.pageCount} />
    </div>
  </section>
</BaseLayout>

<style>
  .posts-page {
    padding-block: clamp(6.5rem, 12vw, 10rem) clamp(4.5rem, 9vw, 8rem);
  }

  .page-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: clamp(2rem, 6vw, 6rem);
    margin-bottom: clamp(2.8rem, 7vw, 5.5rem);
    padding-bottom: clamp(1.8rem, 4vw, 3rem);
    border-bottom: 1px solid var(--color-border, color-mix(in srgb, currentColor 16%, transparent));
  }

  .page-heading h1 {
    max-width: 10ch;
    margin: 0.25rem 0 0;
    font-family: var(--font-display, ui-serif, "Noto Serif SC", serif);
    font-size: clamp(2.7rem, 8vw, 6.4rem);
    font-weight: 650;
    letter-spacing: -0.04em;
    line-height: 0.98;
  }

  .page-heading__intro {
    max-width: 35rem;
    margin: 1.2rem 0 0;
    color: var(--color-text-muted, color-mix(in srgb, currentColor 68%, transparent));
    font-size: clamp(0.96rem, 2vw, 1.08rem);
    line-height: 1.8;
  }

  .page-heading__aside {
    display: grid;
    min-width: min(100%, 15rem);
    gap: 1.1rem;
  }

  .page-heading__aside p {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    margin: 0;
  }

  .page-heading__aside strong {
    color: var(--color-accent-cyan, #087f8c);
    font-family: var(--font-display, ui-serif, serif);
    font-size: 2.2rem;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .page-heading__aside span {
    color: var(--color-text-muted, color-mix(in srgb, currentColor 68%, transparent));
    font-size: 0.8rem;
  }

  .page-heading__aside nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 1rem;
  }

  .page-heading__aside a {
    color: inherit;
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration-color: var(--color-accent-pink, #e76f98);
    text-underline-offset: 0.25em;
  }

  .page-heading__aside a:hover {
    color: var(--color-accent-cyan, #087f8c);
  }

  .post-list {
    max-width: 58rem;
    margin-inline: auto;
  }

  .empty-state {
    max-width: 42rem;
    margin-inline: auto;
    padding: clamp(2rem, 7vw, 4.5rem);
    text-align: center;
  }

  .empty-state > p:first-child {
    color: var(--color-accent-pink, #e76f98);
    font-size: 1.6rem;
  }

  .empty-state h2 {
    margin: 0.5rem 0;
    font-family: var(--font-display, ui-serif, serif);
  }

  .empty-state p:last-child {
    color: var(--color-text-muted, color-mix(in srgb, currentColor 68%, transparent));
  }

  @media (max-width: 680px) {
    .page-heading {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 2rem;
    }
  }
</style>
