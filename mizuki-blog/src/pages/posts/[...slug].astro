---
import PostLayout from "../../layouts/PostLayout.astro";
import { getRelatedPosts, sortPostEntries } from "../../lib/content";
import { loadRuntimePosts } from "../../lib/runtime-content";

const posts = sortPostEntries((await loadRuntimePosts()).filter(({ data }) => !data.draft));
const post = posts.find(({ id }) => id === Astro.params.slug);
if (!post) return Astro.redirect("/404/", 302);
const candidates = posts.map((entry) => ({
  entry,
  id: entry.id,
  publishedAt: entry.data.publishedAt,
  category: entry.data.category,
  tags: entry.data.tags,
  series: entry.data.series,
}));
const index = posts.indexOf(post);
const relatedPosts = getRelatedPosts(candidates[index]!, candidates, 3).map(({ entry }) => entry);
---

<PostLayout
  post={post}
  headings={post.headings}
  relatedPosts={relatedPosts}
  previousPost={posts[index + 1]}
  nextPost={posts[index - 1]}
>
  <Fragment set:html={post.html} />
</PostLayout>
