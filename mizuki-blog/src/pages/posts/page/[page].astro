---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import PostCard from "../../../components/blog/PostCard.astro";
import Pagination from "../../../components/blog/Pagination.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { siteConfig } from "../../../config/site";
import { paginate, sortPostEntries } from "../../../lib/content";

export const getStaticPaths = (async () => {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const pageCount = Math.ceil(posts.length / siteConfig.pageSize);

  return Array.from({ length: Math.max(0, pageCount - 1) }, (_, index) => {
    const page = index + 2;
    return { params: { page: String(page) }, props: { currentPage: page } };
  });
}) satisfies GetStaticPaths;

interface Props {
  currentPage: number;
}

const { currentPage } = Astro.props;
const posts = sortPostEntries(await getCollection("posts", ({ data }) => !data.draft));
const page = paginate(posts, currentPage, siteConfig.pageSize);
---

<BaseLayout
  title={`文章 · 第 ${page.page} 页`}
  description={`浏览 ${siteConfig.name} 的文章索引第 ${page.page} 页，共 ${page.total} 篇公开文章。`}
  class="discovery-page"
>
  <section class="posts-page section" aria-labelledby="posts-title">
    <div class="site-container">
      <header class="page-heading">
        <div>
          <p class="eyebrow">Writing index · 第 {page.page} 页</p>
          <h1 id="posts-title">所有文章</h1>
          <p>按发布时间从新到旧，继续翻阅动画、开发与日常记录。</p>
        </div>
        <p class="page-number" aria-label={`当前第 ${page.page} 页，共 ${page.pageCount} 页`}>
          <strong>{String(page.page).padStart(2, "0")}</strong>
          <span>/ {String(page.pageCount).padStart(2, "0")}</span>
        </p>
      </header>

      <div class="post-list">
        {page.items.map((post) => <PostCard post={post} prominence="compact" />)}
      </div>

      <Pagination currentPage={page.page} pageCount={page.pageCount} />
    </div>
  </section>
</BaseLayout>

<style>
  .posts-page {
    padding-block: clamp(6.5rem, 12vw, 10rem) clamp(4.5rem, 9vw, 8rem);
  }

  .page-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(2.8rem, 7vw, 5.5rem);
    padding-bottom: clamp(1.8rem, 4vw, 3rem);
    border-bottom: 1px solid var(--color-border, color-mix(in srgb, currentColor 16%, transparent));
  }

  .page-heading h1 {
    margin: 0.25rem 0 0;
    font-family: var(--font-display, ui-serif, "Noto Serif SC", serif);
    font-size: clamp(2.7rem, 8vw, 6.4rem);
    font-weight: 650;
    letter-spacing: -0.04em;
    line-height: 0.98;
  }

  .page-heading > div > p:last-child {
    max-width: 35rem;
    margin: 1.2rem 0 0;
    color: var(--color-text-muted, color-mix(in srgb, currentColor 68%, transparent));
    line-height: 1.8;
  }

  .page-number {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .page-number strong {
    color: var(--color-accent-cyan, #087f8c);
    font-family: var(--font-display, ui-serif, serif);
    font-size: 2.8rem;
    font-weight: 560;
  }

  .page-number span {
    color: var(--color-text-muted, color-mix(in srgb, currentColor 60%, transparent));
    font-size: 0.78rem;
  }

  .post-list {
    max-width: 58rem;
    margin-inline: auto;
  }

  @media (max-width: 580px) {
    .page-heading {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
