---
import { Menu, Search } from "lucide-astro";
import { siteConfig } from "../../config/site";
import ThemeToggle from "../ui/ThemeToggle.astro";
import MobileNav from "./MobileNav.astro";

interface Props {
  currentPath?: string;
  overlay?: boolean;
}

const { currentPath = Astro.url.pathname, overlay = false } = Astro.props;

function normalizePath(path: string): string {
  return path === "/" ? path : `${path.replace(/\/+$/, "")}/`;
}

function isCurrent(href: string): boolean {
  const normalizedCurrent = normalizePath(currentPath);
  return href === "/"
    ? normalizedCurrent === "/"
    : normalizedCurrent.startsWith(normalizePath(href));
}
---

<header class:list={["site-header", { "site-header--overlay": overlay }]} data-site-header>
  <div class="site-header__inner site-container">
    <a class="site-brand" href="/" aria-label={`${siteConfig.name} 首页`}>
      <span>{siteConfig.name.slice(0, -1)}</span><b aria-hidden="true">.</b>
    </a>

    <nav class="desktop-nav" aria-label="主导航">
      <ul>
        {siteConfig.navigation.map((item) => (
          <li>
            <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="site-header__actions">
      <a class="icon-button search-link" href="/search/" aria-label="搜索">
        <Search size={18} stroke-width={1.8} aria-hidden="true" />
        <span class="search-link__hint" aria-hidden="true">/</span>
      </a>
      <ThemeToggle />
      <button
        class="icon-button menu-trigger"
        type="button"
        aria-label="打开导航"
        aria-expanded="false"
        aria-controls="mobile-navigation"
        data-nav-trigger
      >
        <Menu size={20} stroke-width={1.8} aria-hidden="true" />
      </button>
    </div>
  </div>
</header>

<MobileNav currentPath={currentPath} />

<style>
  .site-header {
    position: fixed;
    z-index: 70;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: var(--header-height);
    border-block-end: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    color: var(--color-text);
    backdrop-filter: blur(18px) saturate(1.18);
    transition:
      background-color var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      color var(--transition-base);
  }

  .site-header--overlay:not([data-scrolled="true"]) {
    border-color: transparent;
    background: linear-gradient(180deg, rgb(12 20 22 / 34%), transparent);
    color: #fff;
    backdrop-filter: none;
  }

  .site-header[data-scrolled="true"] {
    box-shadow: 0 1px 14px rgb(25 29 30 / 7%);
  }

  .site-header__inner {
    display: flex;
    block-size: 100%;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.5rem);
  }

  .site-brand {
    display: inline-flex;
    align-items: baseline;
    color: currentColor;
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2.5vw, 1.65rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1;
    text-decoration: none;
  }

  .site-brand b {
    color: var(--color-pink);
    font-weight: 700;
  }

  .desktop-nav {
    min-inline-size: 0;
    margin-inline-start: auto;
  }

  .desktop-nav ul {
    display: flex;
    align-items: center;
    gap: clamp(0.65rem, 1.45vw, 1.3rem);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .desktop-nav a {
    position: relative;
    display: inline-flex;
    min-block-size: 2.75rem;
    align-items: center;
    color: color-mix(in srgb, currentColor 78%, transparent);
    font-size: clamp(0.75rem, 0.68rem + 0.12vw, 0.82rem);
    font-weight: 650;
    letter-spacing: 0.025em;
    text-decoration: none;
    white-space: nowrap;
  }

  .desktop-nav a::after {
    position: absolute;
    inset-block-end: 0.25rem;
    inset-inline: 50%;
    block-size: 1px;
    background: var(--color-pink);
    content: "";
    transform: scaleX(0);
    transition: transform var(--transition-fast), inset-inline var(--transition-fast);
  }

  .desktop-nav a:hover,
  .desktop-nav a[aria-current="page"] {
    color: currentColor;
  }

  .desktop-nav a:hover::after,
  .desktop-nav a[aria-current="page"]::after {
    inset-inline: 0;
    transform: scaleX(1);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.1rem;
  }

  .site-header--overlay:not([data-scrolled="true"]) :global(.icon-button) {
    color: rgb(255 255 255 / 88%);
  }

  .site-header--overlay:not([data-scrolled="true"]) :global(.icon-button:hover),
  .site-header--overlay:not([data-scrolled="true"]) :global(.theme-trigger[aria-expanded="true"]) {
    border-color: rgb(255 255 255 / 18%);
    background: rgb(255 255 255 / 12%);
    color: #fff;
  }

  .search-link {
    position: relative;
    text-decoration: none;
  }

  .search-link__hint {
    position: absolute;
    inset-block-start: 0.25rem;
    inset-inline-end: 0.28rem;
    color: currentColor;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    opacity: 0.62;
  }

  .menu-trigger {
    display: none;
  }

  @media (max-width: 1120px) {
    .desktop-nav ul {
      gap: 0.55rem;
    }

    .desktop-nav a {
      font-size: 0.72rem;
    }
  }

  @media (max-width: 899px) {
    .site-header,
    .site-header--overlay:not([data-scrolled="true"]) {
      border-block-end-color: var(--color-border);
      background: color-mix(in srgb, var(--color-bg) 92%, transparent);
      color: var(--color-text);
      backdrop-filter: blur(18px) saturate(1.18);
    }

    .site-header--overlay:not([data-scrolled="true"]) :global(.icon-button) {
      color: var(--color-text-soft);
    }

    .desktop-nav {
      display: none;
    }

    .site-header__actions {
      margin-inline-start: auto;
    }

    .menu-trigger {
      display: inline-grid;
    }
  }
</style>
