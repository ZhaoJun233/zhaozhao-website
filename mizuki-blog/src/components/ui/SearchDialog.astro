---
import { X } from "lucide-astro";
import PagefindSearch from "../integrations/PagefindSearch.astro";
---

<dialog
  id="global-search-dialog"
  class="search-dialog"
  aria-labelledby="global-search-title"
  data-search-dialog
  data-pagefind-ignore
>
  <div class="search-dialog__panel" data-search-dialog-panel>
    <header class="search-dialog__header">
      <div>
        <p>Search · 全站检索</p>
        <h2 id="global-search-title">全站搜索</h2>
      </div>
      <button class="icon-button" type="button" aria-label="关闭搜索" data-search-close>
        <X size={20} stroke-width={1.8} aria-hidden="true" />
      </button>
    </header>

    <PagefindSearch id="global-search" variant="dialog" />
  </div>
</dialog>

<style>
  .search-dialog {
    inline-size: min(52rem, calc(100% - 2rem));
    max-inline-size: none;
    max-block-size: min(46rem, calc(100dvh - 2rem));
    padding: 0;
    overflow: hidden;
    border: 1px solid var(--color-border-strong);
    border-radius: calc(var(--radius-card) + 4px);
    background: color-mix(in srgb, var(--color-bg-elevated) 97%, transparent);
    color: var(--color-text);
    box-shadow: var(--shadow-float);
  }

  .search-dialog::backdrop {
    background: color-mix(in srgb, var(--overlay-scrim) 88%, transparent);
    backdrop-filter: blur(8px) saturate(0.84);
  }

  .search-dialog[open] {
    animation: dialog-enter 220ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .search-dialog__panel {
    max-block-size: min(46rem, calc(100dvh - 2rem));
    padding: clamp(1rem, 3vw, 1.65rem);
    overflow: auto;
    overscroll-behavior: contain;
  }

  .search-dialog__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-block-end: 1.1rem;
  }

  .search-dialog__header p {
    margin: 0 0 0.28rem;
    color: var(--color-accent);
    font-size: 0.62rem;
    font-weight: 740;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .search-dialog__header h2 {
    margin: 0;
    font-size: clamp(1.45rem, 4vw, 2rem);
    letter-spacing: -0.035em;
  }

  .search-dialog__header :global(.icon-button) {
    margin-block-start: -0.25rem;
    margin-inline-end: -0.25rem;
  }

  @keyframes dialog-enter {
    from {
      opacity: 0;
      transform: translateY(-0.7rem) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 520px) {
    .search-dialog {
      inline-size: calc(100% - 1rem);
      max-block-size: calc(100dvh - 1rem);
    }

    .search-dialog__panel {
      max-block-size: calc(100dvh - 1rem);
      padding: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .search-dialog[open] {
      animation: none;
    }
  }
</style>
