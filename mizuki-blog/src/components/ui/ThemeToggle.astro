---
import { Monitor, Moon, Sun, SunMoon } from "lucide-astro";
---

<div class="theme-control" data-theme-control>
  <button
    class="icon-button theme-trigger"
    type="button"
    aria-label="切换配色主题"
    aria-haspopup="menu"
    aria-expanded="false"
    aria-controls="theme-menu"
    data-theme-trigger
  >
    <SunMoon size={18} stroke-width={1.8} aria-hidden="true" />
    <span class="sr-only" data-theme-label>主题：跟随系统</span>
  </button>

  <div class="theme-menu" id="theme-menu" role="menu" aria-label="配色主题" hidden data-theme-menu>
    <span class="theme-menu__label">配色</span>
    <button type="button" role="menuitemradio" aria-checked="false" data-theme-option="light">
      <Sun size={16} stroke-width={1.8} aria-hidden="true" />
      <span>浅色</span>
    </button>
    <button type="button" role="menuitemradio" aria-checked="false" data-theme-option="dark">
      <Moon size={16} stroke-width={1.8} aria-hidden="true" />
      <span>深色</span>
    </button>
    <button type="button" role="menuitemradio" aria-checked="false" data-theme-option="system">
      <Monitor size={16} stroke-width={1.8} aria-hidden="true" />
      <span>系统</span>
    </button>
  </div>
</div>

<style>
  .theme-control {
    position: relative;
  }

  .theme-trigger[aria-expanded="true"] {
    border-color: var(--color-border);
    background: var(--color-bg-soft);
    color: var(--color-accent-strong);
  }

  .theme-menu {
    position: absolute;
    z-index: 80;
    inset-block-start: calc(100% + 0.55rem);
    inset-inline-end: 0;
    inline-size: 10.5rem;
    padding: 0.45rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--color-bg-elevated) 94%, transparent);
    box-shadow: var(--shadow-float);
    backdrop-filter: blur(18px) saturate(1.2);
  }

  .theme-menu__label {
    display: block;
    padding: 0.4rem 0.55rem 0.35rem;
    color: var(--color-text-muted);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .theme-menu button {
    display: flex;
    inline-size: 100%;
    min-block-size: 2.4rem;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0.6rem;
    border: 0;
    border-radius: 5px;
    background: transparent;
    color: var(--color-text-soft);
    cursor: pointer;
    font-size: 0.84rem;
    text-align: start;
  }

  .theme-menu button:hover,
  .theme-menu button[aria-checked="true"] {
    background: var(--color-accent-soft);
    color: var(--color-accent-strong);
  }

  .theme-menu button[aria-checked="true"]::after {
    inline-size: 0.38rem;
    block-size: 0.38rem;
    margin-inline-start: auto;
    border-radius: 50%;
    background: currentColor;
    content: "";
  }

  @media (max-width: 899px) {
    .theme-menu {
      position: fixed;
      inset-block-start: var(--header-height);
      inset-inline-end: var(--page-gutter);
    }
  }
</style>
