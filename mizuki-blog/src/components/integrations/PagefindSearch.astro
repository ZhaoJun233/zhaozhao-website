---
import { getCollection } from "astro:content";
import { RotateCcw, Search } from "lucide-astro";
import { buildTaxonomyIndex } from "../../lib/content";

interface Props {
  id: string;
  variant?: "dialog" | "page";
}

const { id, variant = "page" } = Astro.props;
const posts = await getCollection("posts", ({ data }) => !data.draft);
const categories = buildTaxonomyIndex(posts.map(({ data }) => data.category));
const tags = buildTaxonomyIndex(posts.flatMap(({ data }) => data.tags));
const queryId = `${id}-query`;
const categoryId = `${id}-category`;
const resultsId = `${id}-results`;
---

<section
  class:list={["pagefind-search", `pagefind-search--${variant}`]}
  data-pagefind-search
  data-search-variant={variant}
  data-pagefind-ignore
  aria-label="文章搜索"
>
  <form class="search-form" role="search" data-search-form>
    <label class="sr-only" for={queryId}>搜索文章</label>
    <div class="query-control">
      <Search size={20} stroke-width={1.75} aria-hidden="true" />
      <input
        id={queryId}
        type="search"
        name="query"
        placeholder="输入标题、正文或关键词"
        autocomplete="off"
        spellcheck="false"
        enterkeyhint="search"
        aria-controls={resultsId}
        data-search-input
      />
      <kbd aria-hidden="true">/</kbd>
    </div>

    <div class="search-filters">
      <label class="category-filter" for={categoryId}>
        <span>分类</span>
        <select id={categoryId} name="category" data-search-category>
          <option value="">全部分类</option>
          {categories.map((category) => (
            <option value={category.label}>{category.label}</option>
          ))}
        </select>
      </label>

      <fieldset class="tag-filter">
        <legend>标签 <span>可多选</span></legend>
        <div class="tag-options">
          {tags.map((tag) => (
            <label class="tag-option">
              <input
                type="checkbox"
                name="tag"
                value={tag.label}
                aria-label={tag.label}
                data-search-tag
              />
              <span><i aria-hidden="true">#</i>{tag.label}<small>{tag.count}</small></span>
            </label>
          ))}
        </div>
      </fieldset>

      <button class="reset-search" type="reset" data-search-reset>
        <RotateCcw size={14} stroke-width={1.8} aria-hidden="true" />
        清除条件
      </button>
    </div>
  </form>

  <div class="search-feedback">
    <p data-search-status aria-live="polite" aria-atomic="true">
      输入关键词，或选择分类与标签开始搜索
    </p>
    <p class="index-notice" data-search-index-notice hidden>
      搜索索引将在生产构建后可用
    </p>
  </div>

  <ol id={resultsId} class="search-results" data-search-results aria-label="搜索结果"></ol>

  <section class="search-empty" data-search-empty hidden aria-labelledby={`${id}-empty-title`}>
    <span aria-hidden="true">○</span>
    <h2 id={`${id}-empty-title`} data-search-empty-title></h2>
    <p data-search-empty-message></p>
  </section>
</section>

<style>
  .pagefind-search {
    min-inline-size: 0;
  }

  .search-form {
    display: grid;
    gap: 1rem;
  }

  .query-control {
    position: relative;
    display: flex;
    align-items: center;
  }

  .query-control :global(svg) {
    position: absolute;
    z-index: 1;
    inset-inline-start: 1rem;
    color: var(--color-accent);
    pointer-events: none;
  }

  .query-control input {
    inline-size: 100%;
    min-block-size: 3.45rem;
    padding: 0.8rem 3.35rem 0.8rem 3rem;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-control);
    background: var(--color-bg-elevated);
    color: var(--color-text);
    font-size: clamp(1rem, 2vw, 1.12rem);
    outline: none;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      background-color var(--transition-fast);
  }

  .query-control input::placeholder {
    color: var(--color-text-muted);
  }

  .query-control input:focus {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-focus);
  }

  .query-control kbd {
    position: absolute;
    inset-inline-end: 0.85rem;
    display: inline-grid;
    min-inline-size: 1.55rem;
    block-size: 1.55rem;
    place-items: center;
    border: 1px solid var(--color-border-strong);
    border-block-end-width: 2px;
    border-radius: 4px;
    background: var(--color-bg-soft);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.67rem;
    line-height: 1;
    pointer-events: none;
  }

  .search-filters {
    display: grid;
    min-inline-size: 0;
    align-items: end;
    grid-template-columns: minmax(10rem, 12rem) minmax(0, 1fr) auto;
    gap: 0.85rem;
  }

  .category-filter {
    display: grid;
    gap: 0.42rem;
    color: var(--color-text-muted);
    font-size: 0.68rem;
    font-weight: 720;
    letter-spacing: 0.07em;
  }

  .category-filter select {
    inline-size: 100%;
    min-block-size: 2.55rem;
    padding: 0.58rem 2rem 0.58rem 0.72rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-control);
    background: var(--color-surface-raised);
    color: var(--color-text);
    font-size: 0.78rem;
    font-weight: 620;
  }

  .tag-filter {
    min-inline-size: 0;
    padding: 0;
    margin: 0;
    border: 0;
  }

  .tag-filter legend {
    margin-block-end: 0.42rem;
    color: var(--color-text-muted);
    font-size: 0.68rem;
    font-weight: 720;
    letter-spacing: 0.07em;
  }

  .tag-filter legend span {
    margin-inline-start: 0.25rem;
    font-weight: 520;
    letter-spacing: 0;
  }

  .tag-options {
    display: flex;
    max-block-size: 6.7rem;
    flex-wrap: wrap;
    gap: 0.38rem;
    overflow: auto;
    padding: 0.12rem 0.2rem 0.2rem 0.12rem;
    scrollbar-width: thin;
  }

  .tag-option {
    position: relative;
    cursor: pointer;
  }

  .tag-option input {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    opacity: 0;
  }

  .tag-option > span {
    display: inline-flex;
    min-block-size: 1.85rem;
    align-items: center;
    gap: 0.22rem;
    padding: 0.28rem 0.52rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-size: 0.67rem;
    font-weight: 650;
    line-height: 1;
    transition:
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .tag-option i {
    color: var(--color-pink);
    font-style: normal;
  }

  .tag-option small {
    color: currentColor;
    font-size: 0.58rem;
    font-variant-numeric: tabular-nums;
    opacity: 0.64;
  }

  .tag-option input:checked + span {
    border-color: color-mix(in srgb, var(--color-accent) 58%, var(--color-border));
    background: var(--color-accent-soft);
    color: var(--color-accent-strong);
  }

  .tag-option input:focus-visible + span {
    box-shadow: var(--focus-ring);
  }

  .reset-search {
    display: inline-flex;
    min-block-size: 2.55rem;
    align-items: center;
    justify-content: center;
    gap: 0.38rem;
    padding: 0.55rem 0.72rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-control);
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.68rem;
    font-weight: 680;
    white-space: nowrap;
    cursor: pointer;
  }

  .reset-search:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-strong);
  }

  .search-feedback {
    min-block-size: 2.25rem;
    padding-block: 0.9rem 0.5rem;
    border-block-end: 1px solid var(--color-border);
  }

  .search-feedback p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.72rem;
  }

  .search-feedback .index-notice {
    margin-block-start: 0.45rem;
    color: var(--color-warning);
    font-weight: 680;
  }

  .search-results {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .search-results :global(.search-result) {
    border-block-end: 1px solid var(--color-border);
  }

  .search-results :global(.search-result__link) {
    display: grid;
    gap: 0.52rem;
    padding: clamp(1rem, 2.4vw, 1.4rem) 0.25rem;
    color: inherit;
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      padding-inline var(--transition-fast);
  }

  .search-results :global(.search-result__link:hover),
  .search-results :global(.search-result__link:focus-visible) {
    padding-inline: 0.75rem;
    background: color-mix(in srgb, var(--color-accent-soft) 42%, transparent);
  }

  .search-results :global(.search-result__heading) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .search-results :global(.search-result__title) {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1rem, 2vw, 1.18rem);
    font-weight: 650;
    letter-spacing: -0.016em;
    line-height: 1.35;
  }

  .search-results :global(.search-result__category) {
    flex: 0 0 auto;
    color: var(--color-accent-strong);
    font-size: 0.64rem;
    font-weight: 710;
  }

  .search-results :global(.search-result__excerpt) {
    max-inline-size: 72ch;
    margin: 0;
    color: var(--color-text-soft);
    font-size: 0.78rem;
    line-height: 1.68;
  }

  .search-results :global(mark) {
    padding: 0 0.1em;
    border-radius: 2px;
    background: var(--color-pink-soft);
    color: var(--color-pink-strong);
  }

  .search-results :global(.search-result__tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.62rem;
  }

  .search-empty {
    padding: clamp(2.6rem, 8vw, 5rem) 1rem;
    text-align: center;
  }

  .search-empty > span {
    display: block;
    margin-block-end: 0.65rem;
    color: var(--color-pink);
    font-family: var(--font-serif);
    font-size: 2rem;
  }

  .search-empty h2 {
    margin-block-end: 0.45rem;
    font-size: clamp(1.25rem, 3vw, 1.65rem);
  }

  .search-empty p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .pagefind-search[aria-busy="true"] .search-feedback p:first-child::after {
    display: inline-block;
    inline-size: 1em;
    content: "…";
    animation: search-pulse 850ms ease-in-out infinite alternate;
  }

  @keyframes search-pulse {
    from { opacity: 0.25; }
    to { opacity: 1; }
  }

  @media (max-width: 720px) {
    .search-filters {
      grid-template-columns: 1fr auto;
    }

    .tag-filter {
      grid-column: 1 / -1;
      grid-row: 2;
    }

    .reset-search {
      grid-column: 2;
      grid-row: 1;
    }

    .tag-options {
      max-block-size: 6.7rem;
    }
  }

  @media (max-width: 440px) {
    .query-control input {
      min-block-size: 3.2rem;
      padding-inline-end: 1rem;
    }

    .query-control kbd {
      display: none;
    }

    .search-filters {
      grid-template-columns: 1fr;
    }

    .reset-search,
    .tag-filter {
      grid-column: 1;
      grid-row: auto;
    }

    .reset-search {
      justify-self: start;
    }

    .search-results :global(.search-result__heading) {
      align-items: start;
      flex-direction: column;
      gap: 0.3rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pagefind-search[aria-busy="true"] .search-feedback p:first-child::after {
      animation: none;
    }
  }
</style>
